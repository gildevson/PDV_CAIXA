<Window x:Class="PDV_CAIXA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PDV_CAIXA.Converters"
        Title="PDV Caixa"
        Height="580" Width="900"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage"/>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#7C83FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="KeyBadge" TargetType="Border">
            <Setter Property="Background"        Value="#1A1A2E"/>
            <Setter Property="BorderBrush"       Value="#44475A"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#7C83FF"/>
        </Style>

        <ControlTemplate x:Key="PdvBtnPrimario" TargetType="Button">
            <Border x:Name="bd" Background="#7C83FF" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PdvBtnSecundario" TargetType="Button">
            <Border x:Name="bd" Background="#2A2A3E" BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="NumpadBtn" TargetType="Button">
            <Border x:Name="bd" Background="#252538" BorderBrush="#3A3A55" BorderThickness="1" CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#2A2A48"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#7C83FF"/>
                    <Setter TargetName="bd" Property="BorderBrush" Value="#7C83FF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PdvBtnPerigo" TargetType="Button">
            <Border x:Name="bd" Background="#FF5555" CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#CC3333"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: fixo mas com mínimo -->
            <ColumnDefinition Width="220" MinWidth="200" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ SIDEBAR ══════════════════ -->
        <Border Grid.Column="0" Background="#13131F">
            <DockPanel>

                <!-- Logo topo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Border Background="#7C83FF" CornerRadius="10"
                            Width="40" Height="40" HorizontalAlignment="Center">
                        <TextBlock Text="RME" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PDV Caixa" FontSize="13" FontWeight="Bold"
                               Foreground="#7C83FF" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,14,16,0"/>

                <!-- Perfil do usuário logado -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,16,0,0">

                    <!-- Avatar circular -->
                    <Grid Width="72" Height="72" HorizontalAlignment="Center">
                        <!-- Fundo -->
                        <Ellipse Fill="#252538"/>

                        <!-- Iniciais (placeholder) -->
                        <TextBlock x:Name="txtIniciais"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#7C83FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Foto real via ImageBrush (garante corte circular perfeito) -->
                        <Ellipse x:Name="ellipseAvatar" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgAvatarBrush"
                                            Stretch="UniformToFill"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Anel roxo por cima -->
                        <Ellipse Stroke="#7C83FF" StrokeThickness="2.5" Fill="Transparent"/>
                    </Grid>

                    <TextBlock x:Name="txtNomeUsuario"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="180"
                               Margin="0,10,0,0"/>

                    <Border Background="#2A2A3E" CornerRadius="10"
                            Padding="10,3" HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                        <TextBlock x:Name="txtPerfilUsuario"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7C83FF"/>
                    </Border>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,16,16,0"/>

                <!-- Botão Sair fixado no rodapé -->
                <Button DockPanel.Dock="Bottom"
                        Content="⬅  Sair"
                        Style="{StaticResource MenuButton}"
                        Margin="0,0,0,16"
                        Click="BtnSair_Click"/>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#2A2A3E" Margin="16,0,16,8"/>

                <!-- Itens de menu -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <TextBlock Text="MENU" FontSize="10"
                               Foreground="#44475A" Margin="24,8,0,6"/>

                    <Button x:Name="btnMenuInicio"
                            Content="🏠  Início"
                            Style="{StaticResource MenuButtonActive}"
                            Click="BtnMenuInicio_Click"/>

                    <Button x:Name="btnMenuPDV"
                            Content="🛒  PDV"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuPDV_Click"/>

                    <Button x:Name="btnMenuProdutos"
                            Content="📦  Produtos"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuProdutos_Click"/>

                    <Button x:Name="btnMenuHistorico"
                            Content="📋  Histórico"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuHistorico_Click"/>

                    <Button x:Name="btnMenuPedidos"
                            Content="🔎  Pesq. Pedido"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuPedidos_Click"/>

                    <Button x:Name="btnMenuUsuarios"
                            Content="👥  Usuários"
                            Style="{StaticResource MenuButton}"
                            Visibility="Collapsed"
                            Click="BtnMenuUsuarios_Click"/>

                    <Button x:Name="btnMenuCaixa"
                            Content="🏦  Caixa"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuCaixa_Click"/>

</StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════ CONTEÚDO ══════════════════ -->
        <Grid Grid.Column="1">

            <!-- Página: Início -->
            <StackPanel x:Name="pageInicio"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Bem-vindo ao PDV Caixa"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#E0E0E0"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtBemVindo"
                           FontSize="14" Foreground="#6C6F85"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- ══════════════ PÁGINA: PDV ══════════════ -->
            <Grid x:Name="pagePDV" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" MinWidth="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── ESQUERDA: Busca de Produtos ── -->
                <Border Grid.Column="0" Background="#13131F"
                        BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Cabeçalho do painel -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ADICIONAR PRODUTOS"
                                               Foreground="#7C83FF" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Busque pelo nome ou código de barras"
                                               Foreground="#44475A" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Painel de busca -->
                        <Border DockPanel.Dock="Top" Padding="14,14,14,12" Background="#13131F"
                                BorderBrush="#2A2A3E" BorderThickness="0,1,0,0">
                            <StackPanel>

                                <!-- Campo: Código de barras / Nome -->
                                <TextBlock Text="PRODUTO / CÓD. BARRAS"
                                           Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <TextBox x:Name="pdvTxtBusca"
                                             Height="42" FontSize="13" Padding="38,0,12,0"
                                             Background="#1A1A2E" Foreground="#E0E0E0"
                                             CaretBrush="#7C83FF" BorderBrush="#2A2A3E"
                                             BorderThickness="1.5" VerticalContentAlignment="Center"
                                             TextChanged="PdvTxtBusca_TextChanged"
                                             KeyDown="PdvTxtBusca_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <!-- Ícone lupa -->
                                    <TextBlock Text="🔍" FontSize="14"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <!-- Placeholder -->
                                    <TextBlock Text="Nome ou código de barras..."
                                               Foreground="#3A3A55" FontSize="12"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="38,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=pdvTxtBusca}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Badge F2 -->
                                    <Border Style="{StaticResource KeyBadge}"
                                            HorizontalAlignment="Right" Margin="0,0,8,0">
                                        <TextBlock Text="F2" Style="{StaticResource KeyText}"/>
                                    </Border>
                                </Grid>

                                <!-- Qtd + Botão Adicionar -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Qtd -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="QUANTIDADE"
                                                   Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                                   Margin="0,0,0,5"/>
                                        <TextBox x:Name="pdvTxtQtd"
                                                 Text="1" Height="42" FontSize="16"
                                                 FontWeight="Bold" TextAlignment="Center"
                                                 Background="#1A1A2E" Foreground="#7C83FF"
                                                 CaretBrush="#7C83FF" BorderBrush="#2A2A3E"
                                                 BorderThickness="1.5" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>

                                    <!-- Botão Adicionar -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="AÇÃO"
                                                   Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                                   Margin="0,0,0,5"/>
                                        <Button x:Name="pdvBtnAdicionar"
                                                Height="42" Padding="0"
                                                FontSize="13" FontWeight="Bold"
                                                Foreground="White"
                                                Template="{StaticResource PdvBtnPrimario}"
                                                IsEnabled="False"
                                                Click="PdvBtnAdicionar_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="＋" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Adicionar" VerticalAlignment="Center"/>
                                                <Border Style="{StaticResource KeyBadge}" Margin="8,0,0,0"
                                                        Background="#5558CC" BorderBrush="#7C83FF">
                                                    <TextBlock Text="Enter" Style="{StaticResource KeyText}" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="pdvTxtErroBusca"
                                           Foreground="#FF6B6B" FontSize="11"
                                           Margin="0,8,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Label resultados -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A"
                                Padding="14,8" BorderBrush="#2A2A3E" BorderThickness="0,1,0,1">
                            <Grid>
                                <TextBlock x:Name="pdvTxtLabelResultados"
                                           Text="PRODUTOS DISPONÍVEIS"
                                           Foreground="#44475A" FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Style="{StaticResource KeyBadge}" Margin="0,0,4,0">
                                        <TextBlock Text="↓" Style="{StaticResource KeyText}"/>
                                    </Border>
                                    <TextBlock Text="navegar" Foreground="#3A3A55" FontSize="10"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Lista de produtos -->
                        <ListBox x:Name="pdvLstProdutos"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="PdvLstProdutos_SelectionChanged"
                                 MouseDoubleClick="PdvLstProdutos_DoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8,3" CornerRadius="10" Cursor="Hand"
                                            ClipToBounds="True" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A1A2E"/>
                                                <Setter Property="BorderBrush" Value="#252540"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#22224A"/>
                                                        <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!-- Barra de seleção esquerda -->
                                            <Border Width="4" HorizontalAlignment="Left" CornerRadius="2,0,0,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Background" Value="#7C83FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <!-- Conteúdo do card -->
                                            <Grid Margin="14,10,12,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="46"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar -->
                                                <Border Grid.Column="0" Width="42" Height="42"
                                                        CornerRadius="9" ClipToBounds="True" BorderThickness="1.5">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#5558AA"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Border>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#252545"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                            <Setter Property="Background" Value="#2E2E70"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Iniciais}"
                                                                       FontSize="14" FontWeight="Bold"
                                                                       Foreground="#7C83FF"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Image Stretch="UniformToFill"
                                                               Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                                    </Grid>
                                                </Border>
                                                <!-- Nome + Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                    <TextBlock Text="{Binding Nome}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#D0D0E8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <!-- Código de barras -->
                                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,6,0" Background="#13132A">
                                                            <TextBlock FontFamily="Consolas" FontSize="10"
                                                                       Text="{Binding CodigoBarras, Mode=OneWay, TargetNullValue='sem cód.'}"
                                                                       Foreground="#5558AA"/>
                                                        </Border>
                                                        <!-- Estoque -->
                                                        <Border CornerRadius="4" Padding="5,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#0D1A0D"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                                            <Setter Property="Background" Value="#1A0D0D"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="10">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#4A8A4A"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                                                <Setter Property="Foreground" Value="#8A4A4A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <Run Text="▪ "/><Run Text="{Binding EstoqueTexto, Mode=OneWay}"/><Run Text=" un"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Preço + Badge -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PrecoTexto}"
                                                               FontSize="15" FontWeight="Bold"
                                                               HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#7C83FF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#A0A8FF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Badge SEM ESTOQUE -->
                                                    <Border CornerRadius="4" Background="#2A0A0A"
                                                            BorderBrush="#551818" BorderThickness="1"
                                                            Padding="5,2" Margin="0,4,0,0"
                                                            HorizontalAlignment="Right">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="SEM ESTOQUE" FontSize="9"
                                                                   FontWeight="Bold" Foreground="#CC4444"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- ── DIREITA: Carrinho ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho carrinho -->
                    <Border Grid.Row="0" Padding="16,11"
                            BorderBrush="#2A2A3E" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#16162A" Offset="0"/>
                                <GradientStop Color="#1A1A2E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🛒" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="CARRINHO"
                                           Foreground="#7C83FF" FontSize="12" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <!-- Contador de itens -->
                                <Border x:Name="pdvBadgeItens" Background="#252545" CornerRadius="10"
                                        Padding="8,2" Margin="10,0,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="pdvTxtBadgeItens" Foreground="#9BA2FF"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border Style="{StaticResource KeyBadge}" Margin="0,0,6,0">
                                    <TextBlock Text="Del" Style="{StaticResource KeyText}"/>
                                </Border>
                                <Button Content="Limpar"
                                        Height="28" Padding="12,0" FontSize="11"
                                        Foreground="#A0A0C0"
                                        Template="{StaticResource PdvBtnSecundario}"
                                        Click="PdvBtnLimpar_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid do carrinho -->
                    <DataGrid Grid.Row="1" x:Name="pdvDgCarrinho"
                              AutoGenerateColumns="False"
                              Background="#1E1E2E" RowBackground="#1E1E2E"
                              AlternatingRowBackground="#1A1A2E"
                              Foreground="#E0E0E0" BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A2A3E"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionMode="Single" HeadersVisibility="Column"
                              RowHeight="48" Visibility="Collapsed">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#13131F"/>
                                <Setter Property="Foreground" Value="#7C83FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A2A3E"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUTO" Binding="{Binding Nome}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="UNIT." Binding="{Binding PrecoTexto}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="Foreground" Value="#A0A0C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="QTD" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="−" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold" Foreground="#A0A0C0"
                                                    Tag="{Binding}" Click="PdvBtnMenos_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="#252538"
                                                                CornerRadius="6" BorderBrush="#3A3A55" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Quantidade}"
                                                       Width="36" TextAlignment="Center"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                            <Button Content="+" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold" Foreground="#7C83FF"
                                                    Tag="{Binding}" Click="PdvBtnMais_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="#252538"
                                                                CornerRadius="6" BorderBrush="#3A3A55" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#252545"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding SubtotalTexto}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="44" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="28" Height="28"
                                                FontSize="12" Foreground="White"
                                                Tag="{Binding}"
                                                Template="{StaticResource PdvBtnPerigo}"
                                                Click="PdvBtnRemoverItem_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Estado vazio -->
                    <StackPanel Grid.Row="1" x:Name="pdvPanelVazio"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="40,0">
                        <!-- Ícone com glow -->
                        <Border Width="100" Height="100" CornerRadius="50"
                                HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#1E1E40" Offset="0"/>
                                    <GradientStop Color="#13131F" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C83FF" BlurRadius="30"
                                                  ShadowDepth="0" Opacity="0.12"/>
                            </Border.Effect>
                            <TextBlock Text="🛒" FontSize="44"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <!-- Título -->
                        <TextBlock Text="Carrinho vazio"
                                   Foreground="#4A4A6A" FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <!-- Subtítulo -->
                        <TextBlock Text="Adicione produtos para iniciar a venda"
                                   Foreground="#33334A" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,8,0,28"
                                   TextAlignment="Center"/>
                        <!-- Dica -->
                        <Border Background="#13131F" CornerRadius="10" Padding="16,10"
                                BorderBrush="#2A2A3E" BorderThickness="1"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Use " Foreground="#44475A" FontSize="11" VerticalAlignment="Center"/>
                                <Border Background="#1E1E3E" CornerRadius="5" Padding="7,3" Margin="0,0,4,0">
                                    <TextBlock Text="F2" FontSize="11" Foreground="#7C83FF"
                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text=" para focar na busca" Foreground="#44475A"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Rodapé: total + botões -->
                    <Border Grid.Row="2" Padding="20,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#111120" Offset="0"/>
                                <GradientStop Color="#0D0D1A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="20"
                                              ShadowDepth="0" Opacity="0.5" Direction="90"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Total -->
                            <Border Background="#13131F" CornerRadius="12"
                                    Padding="16,12" Margin="0,0,0,14"
                                    BorderBrush="#2A2A4A" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C83FF" BlurRadius="20"
                                                      ShadowDepth="0" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="pdvTxtTotalItens" Text="0 itens"
                                                   Foreground="#5A5A7A" FontSize="11"/>
                                        <TextBlock Text="Total da venda"
                                                   Foreground="#44445A" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock Text="TOTAL" Foreground="#6C6F85"
                                                   FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="pdvTxtTotal" Text="R$ 0,00"
                                                   FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#7C83FF"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#7C83FF" BlurRadius="14"
                                                                              ShadowDepth="0" Opacity="0.5"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Content="🗑  Limpar Carrinho"
                                            Height="44" FontSize="13" Foreground="#A0A0C0"
                                            Template="{StaticResource PdvBtnSecundario}"
                                            Click="PdvBtnLimpar_Click"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Border Style="{StaticResource KeyBadge}">
                                            <TextBlock Text="Del" Style="{StaticResource KeyText}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" x:Name="pdvBtnFinalizar"
                                            Content="✔  Finalizar Pedido"
                                            Height="44" FontSize="13" FontWeight="Bold"
                                            Foreground="White" IsEnabled="False"
                                            Template="{StaticResource PdvBtnPrimario}"
                                            Click="PdvBtnFinalizar_Click"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Border Style="{StaticResource KeyBadge}">
                                            <TextBlock Text="F12" Style="{StaticResource KeyText}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Página: Produtos -->
            <Grid x:Name="pageProdutos" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ── -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gerenciar Produtos"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center"/>
                        <Border Background="#2A2A3E" CornerRadius="10" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtContadorProdutos" Text="0 produtos"
                                       FontSize="12" Foreground="#7C83FF" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="+ Novo Produto"
                            Height="36" Padding="16,0"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#7C83FF" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnNovoProduto_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Barra de busca + filtro ── -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A1A2E" BorderBrush="#2A2A3E"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                       VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#6C6F85"/>
                            <TextBox Grid.Column="1" x:Name="txtBuscaProduto"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#E0E0E0" CaretBrush="#7C83FF"
                                     FontSize="14" Padding="0,10"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtBuscaProduto_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Resources>
                                            <VisualBrush x:Key="HintP" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Buscar por nome ou código..." Foreground="#6C6F85" FontSize="14"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource HintP}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Filtro Ativo/Todos -->
                    <Border Grid.Column="2" Background="#1A1A2E" BorderBrush="#2A2A3E"
                            BorderThickness="1" CornerRadius="8" Padding="14,0" Cursor="Hand"
                            MouseLeftButtonDown="FiltroAtivo_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="13" Foreground="#6C6F85" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFiltroAtivo" Text="Todos"
                                       Foreground="#7C83FF" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Separador ── -->
                <Border Grid.Row="2" Height="1" Background="#2A2A3E" Margin="0,0,0,0"/>

                <!-- ── DataGrid ── -->
                <DataGrid Grid.Row="3" x:Name="dgProdutos"
                          AutoGenerateColumns="False"
                          Background="#13131F"
                          RowBackground="#1A1A2E"
                          AlternatingRowBackground="#1E1E2E"
                          Foreground="#E0E0E0"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#22223A"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding Ativo}" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <!-- Foto/Iniciais -->
                        <DataGridTemplateColumn Header="" Width="58" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" CornerRadius="8"
                                            Margin="6,0" ClipToBounds="True"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <Border Background="#2A2A3E">
                                                <TextBlock Text="{Binding Iniciais}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#7C83FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Nome -->
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Cód. Barras -->
                        <DataGridTextColumn Header="Cód. Barras" Binding="{Binding CodigoBarras}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#6C6F85"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Preço -->
                        <DataGridTextColumn Header="Preço" Binding="{Binding PrecoTexto}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Estoque -->
                        <DataGridTextColumn Header="Estoque" Binding="{Binding EstoqueTexto}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#C0C0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Situação badge -->
                        <DataGridTemplateColumn Header="Situação" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badgeSit" CornerRadius="6"
                                            Padding="10,4" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="6,0"
                                            Background="#2A5A3A">
                                        <TextBlock x:Name="txtSit" Text="Ativo"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Ativo}" Value="False">
                                            <Setter TargetName="badgeSit" Property="Background" Value="#5A1A1A"/>
                                            <Setter TargetName="txtSit" Property="Text" Value="Inativo"/>
                                            <Setter TargetName="txtSit" Property="Foreground" Value="#FF9090"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Ações -->
                        <DataGridTemplateColumn Header="Ações" Width="195" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#3A3A5A" Foreground="#C0C0E0"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Click="BtnEditarProduto_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Editar" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#5A5A8A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#5A1A1A" Foreground="#FF9090"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnExcluirProduto_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Excluir" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#882222"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ PÁGINA: HISTÓRICO ══════════════ -->
            <Grid x:Name="pageHistorico" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <TextBlock Grid.Row="0" Text="Histórico de Pedidos"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#E0E0E0" Margin="0,0,0,16"/>

                <!-- Cards de resumo -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                            CornerRadius="8" Padding="18,12" Margin="0,0,12,0" MinWidth="160">
                        <StackPanel>
                            <TextBlock Text="PEDIDOS" Foreground="#6C6F85"
                                       FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock x:Name="histTxtQtdPedidos" Text="—"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#7C83FF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                            CornerRadius="8" Padding="18,12" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="FATURAMENTO" Foreground="#6C6F85"
                                       FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock x:Name="histTxtFaturamento" Text="—"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#50FA7B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Filtros de período -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="PERÍODO:" Foreground="#6C6F85"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border x:Name="histFiltroHoje" Background="#2A2A3E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Hoje" Foreground="#7C83FF" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Border x:Name="histFiltroSemana" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Semana" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <Border x:Name="histFiltroMes" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Mês" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <Border x:Name="histFiltroTodos" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,16,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Todos" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <TextBlock x:Name="histTxtContador"
                               Foreground="#44475A" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- DataGrid de pedidos -->
                <DataGrid Grid.Row="3" x:Name="histDgPedidos"
                          AutoGenerateColumns="False"
                          Background="#13131F" RowBackground="#1A1A2E"
                          AlternatingRowBackground="#181828"
                          Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="1"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          SelectionChanged="HistDgPedidos_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="44"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"     Binding="{Binding NumeroTexto}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7C83FF"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Data"  Binding="{Binding DataTexto}"  Width="145">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalTexto}" Width="115">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left" Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#44475A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="finalizado">
                                                        <Setter Property="Background" Value="#00843A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="cancelado">
                                                        <Setter Property="Background" Value="#AA2222"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Pagamento" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3"
                                            HorizontalAlignment="Left" Margin="4,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#44475A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                        <Setter Property="Background" Value="#00843A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                        <Setter Property="Background" Value="#1A5FA8"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                        <Setter Property="Background" Value="#A06010"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="debito">
                                                        <Setter Property="Background" Value="#4A50C0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding PagamentoTexto}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Operador"  Binding="{Binding Operador}"      Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Separador de itens -->
                <Border Grid.Row="4" Background="#0F0F1A" Padding="0,8"
                        BorderBrush="#2A2A3E" BorderThickness="0,1,0,0" Margin="0,4,0,0">
                    <TextBlock x:Name="histTxtDetalhe"
                               Text="Selecione um pedido para ver os itens"
                               Foreground="#6C6F85" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- DataGrid de itens do pedido selecionado -->
                <DataGrid Grid.Row="5" x:Name="histDgItens"
                          AutoGenerateColumns="False"
                          Background="#13131F" RowBackground="#13131F"
                          AlternatingRowBackground="#1A1A2E"
                          Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A2A3E"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#0F0F1A"/>
                            <Setter Property="Foreground" Value="#6C6F85"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto"      Binding="{Binding NomeProduto}"        Width="*"/>
                        <DataGridTextColumn Header="Qtd"          Binding="{Binding Quantidade}"         Width="55"/>
                        <DataGridTextColumn Header="Preço Unit."  Binding="{Binding PrecoUnitarioTexto}" Width="110"/>
                        <DataGridTextColumn Header="Subtotal"     Binding="{Binding SubtotalTexto}"      Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ PÁGINA: PEDIDOS ══════════════ -->
            <Grid x:Name="pagePedidos" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" MinWidth="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── ESQUERDA: Painel de Pesquisa ── -->
                <Border Grid.Column="0" Background="#13131F"
                        BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Cabeçalho -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔎" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PESQUISA DE PEDIDOS"
                                               Foreground="#7C83FF" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Busque por ID ou número sequencial"
                                               Foreground="#44475A" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Botões fixos no rodapé -->
                        <Border DockPanel.Dock="Bottom" Background="#0F0F1A"
                                Padding="12,10" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Limpar / Recentes"
                                        Height="36" FontSize="11" FontWeight="SemiBold"
                                        Foreground="#A0A0C0" Cursor="Hand"
                                        Template="{StaticResource PdvBtnSecundario}"
                                        Click="PedidosBtnLimpar_Click"/>
                                <Button Grid.Column="2" Content="🔍  Buscar"
                                        Height="36" Padding="20,0" FontSize="12" FontWeight="Bold"
                                        Foreground="White" Cursor="Hand"
                                        Template="{StaticResource PdvBtnPrimario}"
                                        Click="PedidosNumpadBuscar_Click"/>
                            </Grid>
                        </Border>

                        <!-- Conteúdo rolável -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,8">

                                <!-- Busca por ID (UUID) -->
                                <TextBlock Text="ID DO PEDIDO (UUID)"
                                           Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="pedidosTxtBuscaId"
                                         Height="40" FontSize="12" Padding="10,0"
                                         Background="#1A1A2E" Foreground="#E0E0E0"
                                         CaretBrush="#7C83FF" BorderBrush="#2A2A3E" BorderThickness="1.5"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         KeyDown="PedidosTxtBuscaId_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Separador OU -->
                                <Grid Margin="0,16,0,16">
                                    <Rectangle Fill="#2A2A3E" Height="1" VerticalAlignment="Center"/>
                                    <Border Background="#13131F" HorizontalAlignment="Center" Padding="10,0">
                                        <TextBlock Text="OU PELO NÚMERO"
                                                   Foreground="#44475A" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- Display numérico -->
                                <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1.5"
                                        CornerRadius="8" Height="58" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock x:Name="pedidosTxtNumero"
                                                   FontSize="30" FontWeight="Bold"
                                                   FontFamily="Consolas"
                                                   Foreground="#7C83FF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <!-- Placeholder quando vazio -->
                                        <TextBlock Text="_ _ _ _"
                                                   FontSize="22" FontWeight="Bold"
                                                   FontFamily="Consolas"
                                                   Foreground="#2A2A3E"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=pedidosTxtNumero}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Teclado numérico -->
                                <UniformGrid Rows="4" Columns="3">
                                    <Button Content="7" Tag="7" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="8" Tag="8" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="9" Tag="9" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="4" Tag="4" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="5" Tag="5" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="6" Tag="6" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="1" Tag="1" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="2" Tag="2" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="3" Tag="3" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="⌫" Height="52" Margin="3"
                                            FontSize="20" Foreground="#FF6B6B" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpadDel_Click"/>
                                    <Button Content="0" Tag="0" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="↵" Height="52" Margin="3"
                                            FontSize="22" Foreground="#7C83FF" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpadBuscar_Click"/>
                                </UniformGrid>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ── DIREITA: Resultados ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="190" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho + DataGrid de pedidos -->
                    <DockPanel Grid.Row="0">
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PEDIDOS" Foreground="#7C83FF"
                                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="pedidosTxtContador"
                                           Foreground="#44475A" FontSize="11"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="dgPedidos"
                                  AutoGenerateColumns="False"
                                  Background="#1E1E2E" RowBackground="#1A1A2E"
                                  AlternatingRowBackground="#181828"
                                  Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" HeadersVisibility="Column"
                                  SelectionChanged="DgPedidos_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#13131F"/>
                                    <Setter Property="Foreground" Value="#7C83FF"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="44"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2A2A5A"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#22223E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"     Binding="{Binding NumeroTexto}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#7C83FF"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Margin" Value="10,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Data"     Binding="{Binding DataTexto}"  Width="135">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Total"    Binding="{Binding TotalTexto}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <!-- Status badge -->
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left" Margin="4,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#44475A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="finalizado">
                                                                <Setter Property="Background" Value="#00843A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="cancelado">
                                                                <Setter Property="Background" Value="#AA2222"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Pagamento badge -->
                                <DataGridTemplateColumn Header="Pagamento" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left" Margin="4,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#44475A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                                <Setter Property="Background" Value="#00843A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                                <Setter Property="Background" Value="#1A5FA8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                                <Setter Property="Background" Value="#A06010"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="debito">
                                                                <Setter Property="Background" Value="#4A50C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PagamentoTexto}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Operador" Binding="{Binding Operador}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- Separador + label de itens -->
                    <Border Grid.Row="1" Background="#0F0F1A" Padding="16,8"
                            BorderBrush="#2A2A3E" BorderThickness="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="pedidosTxtDetalhe"
                                       Text="Selecione um pedido para ver os itens"
                                       Foreground="#6C6F85" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Itens: DataGrid + estado vazio -->
                    <Grid Grid.Row="2">
                        <DataGrid x:Name="dgItensPedido"
                                  AutoGenerateColumns="False"
                                  Background="#13131F" RowBackground="#13131F"
                                  AlternatingRowBackground="#191928"
                                  Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#0F0F1A"/>
                                    <Setter Property="Foreground" Value="#6C6F85"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="10,7"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="38"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto"      Binding="{Binding NomeProduto}"        Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="10,0,0,0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Qtd"          Binding="{Binding Quantidade}"         Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A0C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Preço Unit."  Binding="{Binding PrecoUnitarioTexto}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Subtotal"     Binding="{Binding SubtotalTexto}"      Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Estado vazio -->
                        <StackPanel x:Name="pedidosItensVazio"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="☝" FontSize="36"
                                       HorizontalAlignment="Center" Foreground="#2A2A3E"/>
                            <TextBlock Text="Selecione um pedido acima"
                                       Foreground="#3A3A55" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Página: Usuários -->
            <Grid x:Name="pageUsuarios" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ── -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gerenciar Usuários"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center"/>
                        <Border Background="#2A2A3E" CornerRadius="10" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtUsuarioContador" Text="0 usuários"
                                       FontSize="12" Foreground="#7C83FF" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="+ Novo Usuário"
                            Height="36" Padding="16,0"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#7C83FF" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnNovoUsuario_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Barra de busca ── -->
                <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="#2A2A3E"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#6C6F85"/>
                        <TextBox Grid.Column="1" x:Name="txtBuscaUsuario"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#E0E0E0" CaretBrush="#7C83FF"
                                 FontSize="14" Padding="0,10"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtBuscaUsuario_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Buscar por nome..." Foreground="#6C6F85" FontSize="14"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource Hint}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- ── Separador ── -->
                <Border Grid.Row="2" Height="1" Background="#2A2A3E" Margin="0,0,0,0"/>

                <DataGrid Grid.Row="3" x:Name="dgUsuarios"
                          AutoGenerateColumns="False"
                          Background="#13131F"
                          RowBackground="#1A1A2E"
                          AlternatingRowBackground="#1E1E2E"
                          Foreground="#E0E0E0"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#22223A"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <!-- Avatar -->
                        <DataGridTemplateColumn Header="" Width="58" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" CornerRadius="19"
                                            Margin="6,0" ClipToBounds="True"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <Border Background="#2A2A3E">
                                                <TextBlock Text="{Binding Iniciais}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#7C83FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Nome -->
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Perfil badge -->
                        <DataGridTemplateColumn Header="Perfil" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badgePerfil" CornerRadius="6"
                                            Padding="10,4" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="6,0"
                                            Background="#44475A">
                                        <TextBlock x:Name="txtPerfil" Text="{Binding Perfil}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Perfil}" Value="admin">
                                            <Setter TargetName="badgePerfil" Property="Background" Value="#4A50C0"/>
                                            <Setter TargetName="txtPerfil" Property="Text" Value="Admin"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Perfil}" Value="usuario">
                                            <Setter TargetName="badgePerfil" Property="Background" Value="#2A5A3A"/>
                                            <Setter TargetName="txtPerfil" Property="Text" Value="Usuário"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Ações -->
                        <DataGridTemplateColumn Header="Ações" Width="195" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#3A3A5A" Foreground="#C0C0E0"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Click="BtnEditar_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Editar" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#5A5A8A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#5A1A1A" Foreground="#FF9090"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnExcluir_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Excluir" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#882222"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ PÁGINA: CAIXA ══════════════ -->
            <Grid x:Name="pageCaixa" Visibility="Collapsed">

                <!-- ── Estado: Caixa Fechado ── -->
                <StackPanel x:Name="caixaPanelFechado"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Círculo decorativo externo -->
                    <Border Width="140" Height="140" CornerRadius="70"
                            HorizontalAlignment="Center" Margin="0,0,0,8" Opacity="0.3">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#3A1010" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Ícone principal -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            HorizontalAlignment="Center" Margin="0,-120,0,28">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#2A1010" Offset="0"/>
                                <GradientStop Color="#13131F" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#FF5555" BlurRadius="40" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <TextBlock Text="🔒" FontSize="44"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Caixa Fechado"
                               Foreground="#6A6A8A" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Inicie uma sessão para registrar movimentações"
                               Foreground="#3A3A55" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,8,0,32"
                               TextAlignment="Center"/>
                    <Button Content="📋  Ver histórico de caixas" Height="34" Width="220"
                            FontSize="11" Foreground="#44446A"
                            Cursor="Hand" HorizontalAlignment="Center"
                            Margin="0,0,0,12" Click="BtnHistoricoCaixa_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="8"
                                        BorderBrush="#1E1E38" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#3A3A5A"/>
                                        <Setter TargetName="bd" Property="Background" Value="#10101E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🏦   Abrir Caixa" Height="52" Width="220"
                            FontSize="15" FontWeight="Bold" Foreground="White"
                            Cursor="Hand" HorizontalAlignment="Center"
                            Click="BtnAbrirCaixa_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1A7A35" Offset="0"/>
                                            <GradientStop Color="#128A40" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#50FA7B" BlurRadius="20" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- ── Estado: Caixa Aberto ── -->
                <Grid x:Name="caixaPanelAberto" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ══ BANNER HEADER ══ -->
                    <Border Grid.Row="0" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#071A09" Offset="0"/>
                                <GradientStop Color="#0A120A" Offset="0.5"/>
                                <GradientStop Color="#0F0F1A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="24,18,24,18">
                            <!-- Ícone decorativo de fundo -->
                            <TextBlock Text="🏦" FontSize="120" Opacity="0.04"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,-10,0" IsHitTestVisible="False"/>
                            <!-- Conteúdo esquerdo -->
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Background="#0D2A12" BorderBrush="#1A5A22"
                                            BorderThickness="1" CornerRadius="20" Padding="10,3">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="#50FA7B"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="CAIXA ABERTO" Foreground="#50FA7B"
                                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="caixaTxtAbertura"
                                           Foreground="#3A4A3A" FontSize="11"/>
                            </StackPanel>
                            <!-- Botões direita -->
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Orientation="Horizontal">
                            <!-- Botão histórico -->
                            <Button Height="36" Padding="14,0" Cursor="Hand" Margin="0,0,8,0"
                                    Click="BtnHistoricoCaixa_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="9"
                                                BorderBrush="#1E1E3A" BorderThickness="1"
                                                Background="Transparent">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="4,0">
                                                <TextBlock Text="📋" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Histórico" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#6C6F85" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#14142A"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2A2A4A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Botão fechar -->
                            <Button Height="38" Padding="18,0" Cursor="Hand"
                                    Click="BtnFecharCaixa_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="9"
                                                BorderBrush="#5A2020" BorderThickness="1">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#3A1212" Offset="0"/>
                                                    <GradientStop Color="#2A0D0D" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="4,0">
                                                <TextBlock Text="🔒" FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                <TextBlock Text="Fechar Caixa" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#FF6B6B" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#882222"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ CARDS DE RESUMO ══ -->
                    <Grid Grid.Row="1" Margin="16,14,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── SALDO ATUAL (card maior, destaque) ── -->
                        <Border Grid.Column="0" CornerRadius="14" ClipToBounds="True"
                                BorderBrush="#1E4A22" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0A1E0C" Offset="0"/>
                                    <GradientStop Color="#0E2410" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#50FA7B" BlurRadius="30" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid Margin="20,16,20,16">
                                <!-- Ícone decorativo fundo -->
                                <TextBlock Text="💰" FontSize="72" Opacity="0.07"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,-8,0" IsHitTestVisible="False"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SALDO EM CAIXA" Foreground="#2A6A30"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="caixaTxtSaldo" Text="R$ 0,00"
                                               FontSize="32" FontWeight="Bold" Margin="0,8,0,4">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#50FA7B" Offset="0"/>
                                                <GradientStop Color="#88FFAA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#50FA7B" BlurRadius="14" ShadowDepth="0" Opacity="0.45"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="disponível no caixa" Foreground="#244A26"
                                               FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── ENTRADAS ── -->
                        <Border Grid.Column="2" CornerRadius="14" ClipToBounds="True"
                                BorderBrush="#1A3A1A" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0A180A" Offset="0"/>
                                    <GradientStop Color="#0D1E0D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid Margin="16,14,16,14">
                                <TextBlock Text="⬆" FontSize="56" Opacity="0.06"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ENTRADAS" Foreground="#2A4A2A"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="caixaTxtEntradas" Text="R$ 0,00"
                                               Foreground="#48B848" FontSize="22" FontWeight="Bold"
                                               Margin="0,7,0,3"/>
                                    <TextBlock Text="recebido" Foreground="#1E381E"
                                               FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── SAÍDAS ── -->
                        <Border Grid.Column="4" CornerRadius="14" ClipToBounds="True"
                                BorderBrush="#3A1A1A" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A0A0A" Offset="0"/>
                                    <GradientStop Color="#200E0E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid Margin="16,14,16,14">
                                <TextBlock Text="⬇" FontSize="56" Opacity="0.06"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SAÍDAS" Foreground="#4A2A2A"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="caixaTxtSaidas" Text="R$ 0,00"
                                               Foreground="#CC4444" FontSize="22" FontWeight="Bold"
                                               Margin="0,7,0,3"/>
                                    <TextBlock Text="gasto" Foreground="#3A1A1A"
                                               FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ══ BARRA DE AÇÕES ══ -->
                    <Grid Grid.Row="2" Margin="16,12,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nova Entrada -->
                        <Button Grid.Column="0" Height="42" Padding="20,0"
                                Cursor="Hand" Click="BtnNovaEntrada_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                            BorderBrush="#2A7A2A">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1A6A25" Offset="0"/>
                                                <GradientStop Color="#155520" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="#1E8A2E" CornerRadius="5"
                                                    Width="22" Height="22" Margin="0,0,9,0">
                                                <TextBlock Text="＋" FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Nova Entrada" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Nova Saída -->
                        <Button Grid.Column="2" Height="42" Padding="20,0"
                                Cursor="Hand" Click="BtnNovaSaida_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                            BorderBrush="#7A2A2A">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#6A1A1A" Offset="0"/>
                                                <GradientStop Color="#551515" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="#882222" CornerRadius="5"
                                                    Width="22" Height="22" Margin="0,0,9,0">
                                                <TextBlock Text="－" FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Nova Saída" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Label movimentações -->
                        <TextBlock Grid.Column="4" Text="MOVIMENTAÇÕES DO DIA"
                                   Foreground="#2A2A3E" FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- ══ LISTA DE MOVIMENTAÇÕES ══ -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">

                        <!-- DataGrid -->
                        <DataGrid x:Name="caixaDgMovimentacoes"
                                  AutoGenerateColumns="False"
                                  Background="#1E1E2E" RowBackground="#1E1E2E"
                                  AlternatingRowBackground="#1A1A28"
                                  Foreground="#E0E0E0" BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#22223A"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" HeadersVisibility="Column"
                                  RowHeight="50">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#111120"/>
                                    <Setter Property="Foreground" Value="#44475A"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="14,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#222235"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#252545"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <!-- Data/Hora -->
                                <DataGridTextColumn Header="DATA / HORA" Binding="{Binding DataTexto}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="14,0"/>
                                            <Setter Property="Foreground" Value="#5A5A7A"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <!-- Tipo badge -->
                                <DataGridTemplateColumn Header="TIPO" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="12,5" Margin="10,0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0A1A0A"/>
                                                        <Setter Property="BorderBrush" Value="#1A4A1A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="saida">
                                                                <Setter Property="Background" Value="#1A0A0A"/>
                                                                <Setter Property="BorderBrush" Value="#4A1A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11"
                                                               Margin="0,0,6,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="⬆"/>
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tipo}" Value="saida">
                                                                        <Setter Property="Text" Value="⬇"/>
                                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding TipoTexto}"
                                                               FontSize="11" FontWeight="Bold"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tipo}" Value="saida">
                                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Descrição -->
                                <DataGridTextColumn Header="DESCRIÇÃO" Binding="{Binding Descricao}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                            <Setter Property="Foreground" Value="#C0C0D8"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <!-- Origem -->
                                <DataGridTemplateColumn Header="ORIGEM" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="9,3" Margin="10,0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A1A35"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Origem}" Value="venda">
                                                                <Setter Property="Background" Value="#1A1A35"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11"
                                                               Margin="0,0,5,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✏"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Origem}" Value="venda">
                                                                        <Setter Property="Text" Value="🛒"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding OrigemTexto}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#7C83FF"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Valor -->
                                <DataGridTemplateColumn Header="VALOR" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ValorTexto}"
                                                       FontSize="15" FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,20,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#50FA7B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="saida">
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Estado vazio da lista -->
                        <StackPanel x:Name="caixaEmptyState"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Margin="0,60,0,0" Visibility="Visible">
                            <TextBlock Text="📋" FontSize="40"
                                       HorizontalAlignment="Center" Opacity="0.2"/>
                            <TextBlock Text="Nenhuma movimentação hoje"
                                       Foreground="#2A2A3E" FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Use os botões acima para registrar entradas e saídas"
                                       Foreground="#22223A" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ── Estado: Histórico de Caixas ── -->
                <Grid x:Name="caixaPanelHistorico" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header do histórico -->
                    <Border Grid.Row="0" Padding="20,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#080812" Offset="0"/>
                                <GradientStop Color="#0E0E1C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Botão voltar -->
                                <Button Cursor="Hand" Margin="0,0,18,0"
                                        Click="BtnVoltarCaixa_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="9"
                                                    Padding="12,7" BorderBrush="#1E1E38" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="←" Foreground="#6C6F85" FontSize="13"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Voltar" Foreground="#6C6F85" FontSize="12"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#12121E"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#2A2A4A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Título -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="HISTÓRICO DE CAIXAS" Foreground="#44446A"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock Text="Sessões de abertura e fechamento" Foreground="#D0D0E0"
                                               FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Contador de sessões -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="#12121E" CornerRadius="10" Padding="14,8">
                                <StackPanel>
                                    <TextBlock x:Name="caixaHistoricoTxtTotal" Text="0 sessões"
                                               Foreground="#6C6F85" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#14142A"/>

                    <!-- DataGrid de sessões -->
                    <DataGrid Grid.Row="1" x:Name="caixaDgHistorico"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="#0C0C18" AlternatingRowBackground="#0F0F1E"
                              Foreground="#B0B0D0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#14142A"
                              ColumnHeaderHeight="38" RowHeight="52"
                              SelectionMode="Single"
                              CanUserResizeColumns="False" CanUserSortColumns="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"       Value="#08080E"/>
                                <Setter Property="Foreground"       Value="#40406A"/>
                                <Setter Property="FontSize"         Value="10"/>
                                <Setter Property="FontWeight"       Value="Bold"/>
                                <Setter Property="Padding"          Value="16,0"/>
                                <Setter Property="BorderBrush"      Value="#14142A"/>
                                <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                                <Setter Property="SeparatorBrush"   Value="#1A1A2E"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderBrush"     Value="#12122A"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#14142E"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A1A38"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="16,0" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>

                            <!-- STATUS -->
                            <DataGridTemplateColumn Header="STATUS" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A1A2E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="aberto">
                                                            <Setter Property="Background" Value="#0C2014"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="⏹ FECHADO"/>
                                                        <Setter Property="Foreground" Value="#44446A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="aberto">
                                                                <Setter Property="Text"       Value="● ABERTO"/>
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ABERTURA -->
                            <DataGridTemplateColumn Header="ABERTURA" Width="155">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding AberturaTexto}" Foreground="#C0C0E0"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- FECHAMENTO -->
                            <DataGridTemplateColumn Header="FECHAMENTO" Width="155">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FechamentoTexto}" Foreground="#6C6F85"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- DURAÇÃO -->
                            <DataGridTemplateColumn Header="DURAÇÃO" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DuracaoTexto}" Foreground="#55557A"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- SALDO INICIAL -->
                            <DataGridTemplateColumn Header="SALDO INICIAL" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SaldoInicialTexto}" Foreground="#7070A0"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ENTRADAS -->
                            <DataGridTemplateColumn Header="ENTRADAS" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EntradasTexto}" Foreground="#50FA7B"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- SAÍDAS -->
                            <DataGridTemplateColumn Header="SAÍDAS" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SaidasTexto}" Foreground="#FF5555"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- SALDO FINAL -->
                            <DataGridTemplateColumn Header="SALDO FINAL" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SaldoFinalTexto}" Foreground="#E0E0F8"
                                                   FontSize="13" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>

            <!-- ══════════════ OVERLAY DE CARREGAMENTO ══════════════ -->
            <Grid x:Name="overlayCarregando"
                  Visibility="Collapsed"
                  Panel.ZIndex="999"
                  Background="#CC1E1E2E">
                <Border Background="#252538"
                        BorderBrush="#3A3A55" BorderThickness="1"
                        CornerRadius="14" Padding="48,36"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">

                        <!-- Spinner: borda parcial girando -->
                        <Border x:Name="spinnerBorder"
                                Width="52" Height="52"
                                BorderBrush="#7C83FF"
                                BorderThickness="5,5,0,0"
                                CornerRadius="26"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="spinnerRotate" Angle="0"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard x:Name="spinnerStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="spinnerRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:0.75"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>

                        <TextBlock x:Name="overlayTxtMensagem"
                                   Text="Carregando..."
                                   Foreground="#E0E0E0"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
