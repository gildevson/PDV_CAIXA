<Window x:Class="PDV_CAIXA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PDV_CAIXA.Converters"
        Title="PDV Caixa"
        Height="580" Width="900"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage"/>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#7C83FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="KeyBadge" TargetType="Border">
            <Setter Property="Background"        Value="#1A1A2E"/>
            <Setter Property="BorderBrush"       Value="#44475A"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#7C83FF"/>
        </Style>

        <ControlTemplate x:Key="PdvBtnPrimario" TargetType="Button">
            <Border x:Name="bd" Background="#7C83FF" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PdvBtnSecundario" TargetType="Button">
            <Border x:Name="bd" Background="#2A2A3E" BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="NumpadBtn" TargetType="Button">
            <Border x:Name="bd" Background="#252538" BorderBrush="#3A3A55" BorderThickness="1" CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#2A2A48"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#7C83FF"/>
                    <Setter TargetName="bd" Property="BorderBrush" Value="#7C83FF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PdvBtnPerigo" TargetType="Button">
            <Border x:Name="bd" Background="#FF5555" CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#CC3333"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: fixo mas com mínimo -->
            <ColumnDefinition Width="220" MinWidth="200" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ SIDEBAR ══════════════════ -->
        <Border Grid.Column="0" Background="#13131F">
            <DockPanel>

                <!-- Logo topo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Border Background="#7C83FF" CornerRadius="10"
                            Width="40" Height="40" HorizontalAlignment="Center">
                        <TextBlock Text="RME" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PDV Caixa" FontSize="13" FontWeight="Bold"
                               Foreground="#7C83FF" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,14,16,0"/>

                <!-- Perfil do usuário logado -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,16,0,0">

                    <!-- Avatar circular -->
                    <Grid Width="72" Height="72" HorizontalAlignment="Center">
                        <!-- Fundo -->
                        <Ellipse Fill="#252538"/>

                        <!-- Iniciais (placeholder) -->
                        <TextBlock x:Name="txtIniciais"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#7C83FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Foto real via ImageBrush (garante corte circular perfeito) -->
                        <Ellipse x:Name="ellipseAvatar" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgAvatarBrush"
                                            Stretch="UniformToFill"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Anel roxo por cima -->
                        <Ellipse Stroke="#7C83FF" StrokeThickness="2.5" Fill="Transparent"/>
                    </Grid>

                    <TextBlock x:Name="txtNomeUsuario"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="180"
                               Margin="0,10,0,0"/>

                    <Border Background="#2A2A3E" CornerRadius="10"
                            Padding="10,3" HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                        <TextBlock x:Name="txtPerfilUsuario"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7C83FF"/>
                    </Border>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,16,16,0"/>

                <!-- Botão Sair fixado no rodapé -->
                <Button DockPanel.Dock="Bottom"
                        Content="⬅  Sair"
                        Style="{StaticResource MenuButton}"
                        Margin="0,0,0,16"
                        Click="BtnSair_Click"/>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#2A2A3E" Margin="16,0,16,8"/>

                <!-- Itens de menu -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <TextBlock Text="MENU" FontSize="10"
                               Foreground="#44475A" Margin="24,8,0,6"/>

                    <Button x:Name="btnMenuInicio"
                            Content="🏠  Início"
                            Style="{StaticResource MenuButtonActive}"
                            Click="BtnMenuInicio_Click"/>

                    <Button x:Name="btnMenuPDV"
                            Content="🛒  PDV"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuPDV_Click"/>

                    <Button x:Name="btnMenuProdutos"
                            Content="📦  Produtos"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuProdutos_Click"/>

                    <Button x:Name="btnMenuHistorico"
                            Content="📋  Histórico"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuHistorico_Click"/>

                    <Button x:Name="btnMenuPedidos"
                            Content="🔎  Pesq. Pedido"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMenuPedidos_Click"/>

                    <Button x:Name="btnMenuUsuarios"
                            Content="👥  Usuários"
                            Style="{StaticResource MenuButton}"
                            Visibility="Collapsed"
                            Click="BtnMenuUsuarios_Click"/>

</StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════ CONTEÚDO ══════════════════ -->
        <Grid Grid.Column="1">

            <!-- Página: Início -->
            <StackPanel x:Name="pageInicio"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Bem-vindo ao PDV Caixa"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#E0E0E0"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtBemVindo"
                           FontSize="14" Foreground="#6C6F85"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- ══════════════ PÁGINA: PDV ══════════════ -->
            <Grid x:Name="pagePDV" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" MinWidth="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── ESQUERDA: Busca de Produtos ── -->
                <Border Grid.Column="0" Background="#13131F"
                        BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Cabeçalho do painel -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ADICIONAR PRODUTOS"
                                               Foreground="#7C83FF" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Busque pelo nome ou código de barras"
                                               Foreground="#44475A" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Painel de busca -->
                        <Border DockPanel.Dock="Top" Padding="14,14,14,12" Background="#13131F"
                                BorderBrush="#2A2A3E" BorderThickness="0,1,0,0">
                            <StackPanel>

                                <!-- Campo: Código de barras / Nome -->
                                <TextBlock Text="PRODUTO / CÓD. BARRAS"
                                           Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <TextBox x:Name="pdvTxtBusca"
                                             Height="42" FontSize="13" Padding="38,0,12,0"
                                             Background="#1A1A2E" Foreground="#E0E0E0"
                                             CaretBrush="#7C83FF" BorderBrush="#2A2A3E"
                                             BorderThickness="1.5" VerticalContentAlignment="Center"
                                             TextChanged="PdvTxtBusca_TextChanged"
                                             KeyDown="PdvTxtBusca_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <!-- Ícone lupa -->
                                    <TextBlock Text="🔍" FontSize="14"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <!-- Placeholder -->
                                    <TextBlock Text="Nome ou código de barras..."
                                               Foreground="#3A3A55" FontSize="12"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="38,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=pdvTxtBusca}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Badge F2 -->
                                    <Border Style="{StaticResource KeyBadge}"
                                            HorizontalAlignment="Right" Margin="0,0,8,0">
                                        <TextBlock Text="F2" Style="{StaticResource KeyText}"/>
                                    </Border>
                                </Grid>

                                <!-- Qtd + Botão Adicionar -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Qtd -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="QUANTIDADE"
                                                   Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                                   Margin="0,0,0,5"/>
                                        <TextBox x:Name="pdvTxtQtd"
                                                 Text="1" Height="42" FontSize="16"
                                                 FontWeight="Bold" TextAlignment="Center"
                                                 Background="#1A1A2E" Foreground="#7C83FF"
                                                 CaretBrush="#7C83FF" BorderBrush="#2A2A3E"
                                                 BorderThickness="1.5" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>

                                    <!-- Botão Adicionar -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="AÇÃO"
                                                   Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                                   Margin="0,0,0,5"/>
                                        <Button x:Name="pdvBtnAdicionar"
                                                Height="42" Padding="0"
                                                FontSize="13" FontWeight="Bold"
                                                Foreground="White"
                                                Template="{StaticResource PdvBtnPrimario}"
                                                IsEnabled="False"
                                                Click="PdvBtnAdicionar_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="＋" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Adicionar" VerticalAlignment="Center"/>
                                                <Border Style="{StaticResource KeyBadge}" Margin="8,0,0,0"
                                                        Background="#5558CC" BorderBrush="#7C83FF">
                                                    <TextBlock Text="Enter" Style="{StaticResource KeyText}" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="pdvTxtErroBusca"
                                           Foreground="#FF6B6B" FontSize="11"
                                           Margin="0,8,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Label resultados -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A"
                                Padding="14,8" BorderBrush="#2A2A3E" BorderThickness="0,1,0,1">
                            <Grid>
                                <TextBlock x:Name="pdvTxtLabelResultados"
                                           Text="PRODUTOS DISPONÍVEIS"
                                           Foreground="#44475A" FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Style="{StaticResource KeyBadge}" Margin="0,0,4,0">
                                        <TextBlock Text="↓" Style="{StaticResource KeyText}"/>
                                    </Border>
                                    <TextBlock Text="navegar" Foreground="#3A3A55" FontSize="10"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Lista de produtos -->
                        <ListBox x:Name="pdvLstProdutos"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="PdvLstProdutos_SelectionChanged"
                                 MouseDoubleClick="PdvLstProdutos_DoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2A3E" BorderThickness="0,0,0,1"
                                            Padding="14,10" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#252538"/>
                                                    </DataTrigger>
                                                    <!-- Escurece produtos sem estoque -->
                                                    <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="6" ClipToBounds="True">
                                                <Grid>
                                                    <Border Background="#252538">
                                                        <TextBlock Text="{Binding Iniciais}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="#7C83FF"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Image Stretch="UniformToFill"
                                                           Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="{Binding Nome}"
                                                           Foreground="#E0E0E0" FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <!-- Código de barras -->
                                                    <Border Background="#1A1A2E" CornerRadius="3"
                                                            Padding="5,1" Margin="0,0,6,0">
                                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                                   Foreground="#7C83FF">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="sem cód."/>
                                                                    <Setter Property="Foreground" Value="#3A3A55"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding CodigoBarras}" Value="{x:Null}">
                                                                            <Setter Property="Text" Value="sem cód."/>
                                                                            <Setter Property="Foreground" Value="#3A3A55"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding CodigoBarras, Mode=OneWay, TargetNullValue='sem cód.'}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <!-- Estoque -->
                                                    <TextBlock Foreground="#6C6F85" FontSize="10" VerticalAlignment="Center">
                                                        <Run Text="Estoque: "/>
                                                        <Run Text="{Binding EstoqueTexto, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Preço ou badge sem estoque -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding PrecoTexto}"
                                                           Foreground="#7C83FF" FontSize="14"
                                                           FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <!-- Badge "SEM ESTOQUE" visível só quando Estoque = 0 -->
                                                <Border CornerRadius="4" Background="#3A1010"
                                                        BorderBrush="#662222" BorderThickness="1"
                                                        Padding="5,2" Margin="0,3,0,0"
                                                        HorizontalAlignment="Right">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Estoque}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="SEM ESTOQUE" FontSize="9"
                                                               FontWeight="Bold" Foreground="#FF5555"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- ── DIREITA: Carrinho ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho carrinho + atalhos -->
                    <Border Grid.Row="0" Background="#1A1A2E" Padding="16,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🛒  CARRINHO"
                                           Foreground="#7C83FF" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                            <!-- Atalhos rápidos -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Style="{StaticResource KeyBadge}" Margin="0,0,4,0">
                                    <TextBlock Text="Del" Style="{StaticResource KeyText}"/>
                                </Border>
                                <TextBlock Text="Limpar  " Foreground="#44475A" FontSize="10" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource KeyBadge}" Margin="0,0,4,0">
                                    <TextBlock Text="F12" Style="{StaticResource KeyText}"/>
                                </Border>
                                <TextBlock Text="Finalizar" Foreground="#44475A" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Style="{StaticResource KeyBadge}" Margin="0,0,6,0">
                                    <TextBlock Text="Del" Style="{StaticResource KeyText}"/>
                                </Border>
                                <Button Content="Limpar tudo"
                                        Height="28" Padding="12,0" FontSize="11"
                                        Foreground="#A0A0C0"
                                        Template="{StaticResource PdvBtnSecundario}"
                                        Click="PdvBtnLimpar_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid do carrinho -->
                    <DataGrid Grid.Row="1" x:Name="pdvDgCarrinho"
                              AutoGenerateColumns="False"
                              Background="#1E1E2E" RowBackground="#1E1E2E"
                              AlternatingRowBackground="#1A1A2E"
                              Foreground="#E0E0E0" BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A2A3E"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionMode="Single" HeadersVisibility="Column"
                              RowHeight="48" Visibility="Collapsed">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#13131F"/>
                                <Setter Property="Foreground" Value="#7C83FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A2A3E"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUTO" Binding="{Binding Nome}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="UNIT." Binding="{Binding PrecoTexto}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="Foreground" Value="#A0A0C0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="QTD" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="−" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold" Foreground="#A0A0C0"
                                                    Tag="{Binding}" Click="PdvBtnMenos_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="#252538"
                                                                CornerRadius="6" BorderBrush="#3A3A55" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Quantidade}"
                                                       Width="36" TextAlignment="Center"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                            <Button Content="+" Width="28" Height="28"
                                                    FontSize="16" FontWeight="Bold" Foreground="#7C83FF"
                                                    Tag="{Binding}" Click="PdvBtnMais_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="#252538"
                                                                CornerRadius="6" BorderBrush="#3A3A55" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#252545"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="SUBTOTAL" Binding="{Binding SubtotalTexto}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="44" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="28" Height="28"
                                                FontSize="12" Foreground="White"
                                                Tag="{Binding}"
                                                Template="{StaticResource PdvBtnPerigo}"
                                                Click="PdvBtnRemoverItem_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Estado vazio -->
                    <StackPanel Grid.Row="1" x:Name="pdvPanelVazio"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🛒" FontSize="52"
                                   HorizontalAlignment="Center" Opacity="0.15"/>
                        <TextBlock Text="Nenhum item no carrinho"
                                   Foreground="#44475A" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Busque um produto à esquerda e clique em Adicionar"
                                   Foreground="#3A3A55" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Rodapé: total + botões -->
                    <Border Grid.Row="2" Background="#13131F" Padding="20,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock x:Name="pdvTxtTotalItens" Text="0 itens"
                                           Foreground="#6C6F85" FontSize="12" VerticalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock Text="TOTAL" Foreground="#8888AA"
                                               FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="pdvTxtTotal" Text="R$ 0,00"
                                               Foreground="#7C83FF" FontSize="26"
                                               FontWeight="Bold" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Content="🗑  Limpar Carrinho"
                                            Height="44" FontSize="13" Foreground="#A0A0C0"
                                            Template="{StaticResource PdvBtnSecundario}"
                                            Click="PdvBtnLimpar_Click"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Border Style="{StaticResource KeyBadge}">
                                            <TextBlock Text="Del" Style="{StaticResource KeyText}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" x:Name="pdvBtnFinalizar"
                                            Content="✔  Finalizar Pedido"
                                            Height="44" FontSize="13" FontWeight="Bold"
                                            Foreground="White" IsEnabled="False"
                                            Template="{StaticResource PdvBtnPrimario}"
                                            Click="PdvBtnFinalizar_Click"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Border Style="{StaticResource KeyBadge}">
                                            <TextBlock Text="F12" Style="{StaticResource KeyText}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Página: Produtos -->
            <Grid x:Name="pageProdutos" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ── -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gerenciar Produtos"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center"/>
                        <Border Background="#2A2A3E" CornerRadius="10" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtContadorProdutos" Text="0 produtos"
                                       FontSize="12" Foreground="#7C83FF" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="+ Novo Produto"
                            Height="36" Padding="16,0"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#7C83FF" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnNovoProduto_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Barra de busca + filtro ── -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A1A2E" BorderBrush="#2A2A3E"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                       VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#6C6F85"/>
                            <TextBox Grid.Column="1" x:Name="txtBuscaProduto"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#E0E0E0" CaretBrush="#7C83FF"
                                     FontSize="14" Padding="0,10"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtBuscaProduto_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Resources>
                                            <VisualBrush x:Key="HintP" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Buscar por nome ou código..." Foreground="#6C6F85" FontSize="14"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource HintP}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Filtro Ativo/Todos -->
                    <Border Grid.Column="2" Background="#1A1A2E" BorderBrush="#2A2A3E"
                            BorderThickness="1" CornerRadius="8" Padding="14,0" Cursor="Hand"
                            MouseLeftButtonDown="FiltroAtivo_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="13" Foreground="#6C6F85" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFiltroAtivo" Text="Todos"
                                       Foreground="#7C83FF" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Separador ── -->
                <Border Grid.Row="2" Height="1" Background="#2A2A3E" Margin="0,0,0,0"/>

                <!-- ── DataGrid ── -->
                <DataGrid Grid.Row="3" x:Name="dgProdutos"
                          AutoGenerateColumns="False"
                          Background="#13131F"
                          RowBackground="#1A1A2E"
                          AlternatingRowBackground="#1E1E2E"
                          Foreground="#E0E0E0"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#22223A"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding Ativo}" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <!-- Foto/Iniciais -->
                        <DataGridTemplateColumn Header="" Width="58" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" CornerRadius="8"
                                            Margin="6,0" ClipToBounds="True"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <Border Background="#2A2A3E">
                                                <TextBlock Text="{Binding Iniciais}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#7C83FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Nome -->
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Cód. Barras -->
                        <DataGridTextColumn Header="Cód. Barras" Binding="{Binding CodigoBarras}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#6C6F85"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Preço -->
                        <DataGridTextColumn Header="Preço" Binding="{Binding PrecoTexto}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Estoque -->
                        <DataGridTextColumn Header="Estoque" Binding="{Binding EstoqueTexto}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#C0C0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Situação badge -->
                        <DataGridTemplateColumn Header="Situação" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badgeSit" CornerRadius="6"
                                            Padding="10,4" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="6,0"
                                            Background="#2A5A3A">
                                        <TextBlock x:Name="txtSit" Text="Ativo"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Ativo}" Value="False">
                                            <Setter TargetName="badgeSit" Property="Background" Value="#5A1A1A"/>
                                            <Setter TargetName="txtSit" Property="Text" Value="Inativo"/>
                                            <Setter TargetName="txtSit" Property="Foreground" Value="#FF9090"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Ações -->
                        <DataGridTemplateColumn Header="Ações" Width="195" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#3A3A5A" Foreground="#C0C0E0"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Click="BtnEditarProduto_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Editar" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#5A5A8A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#5A1A1A" Foreground="#FF9090"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnExcluirProduto_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Excluir" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#882222"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ PÁGINA: HISTÓRICO ══════════════ -->
            <Grid x:Name="pageHistorico" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <TextBlock Grid.Row="0" Text="Histórico de Pedidos"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#E0E0E0" Margin="0,0,0,16"/>

                <!-- Cards de resumo -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                            CornerRadius="8" Padding="18,12" Margin="0,0,12,0" MinWidth="160">
                        <StackPanel>
                            <TextBlock Text="PEDIDOS" Foreground="#6C6F85"
                                       FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock x:Name="histTxtQtdPedidos" Text="—"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#7C83FF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1"
                            CornerRadius="8" Padding="18,12" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="FATURAMENTO" Foreground="#6C6F85"
                                       FontSize="10" FontWeight="SemiBold"/>
                            <TextBlock x:Name="histTxtFaturamento" Text="—"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#50FA7B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Filtros de período -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="PERÍODO:" Foreground="#6C6F85"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border x:Name="histFiltroHoje" Background="#2A2A3E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Hoje" Foreground="#7C83FF" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Border x:Name="histFiltroSemana" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Semana" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <Border x:Name="histFiltroMes" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,6,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Mês" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <Border x:Name="histFiltroTodos" Background="#1A1A2E" CornerRadius="6"
                            Padding="12,5" Margin="0,0,16,0" Cursor="Hand"
                            MouseLeftButtonDown="HistFiltro_Click">
                        <TextBlock Text="Todos" Foreground="#A0A0C0" FontSize="12"/>
                    </Border>
                    <TextBlock x:Name="histTxtContador"
                               Foreground="#44475A" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- DataGrid de pedidos -->
                <DataGrid Grid.Row="3" x:Name="histDgPedidos"
                          AutoGenerateColumns="False"
                          Background="#13131F" RowBackground="#1A1A2E"
                          AlternatingRowBackground="#181828"
                          Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="1"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          SelectionChanged="HistDgPedidos_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="44"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"     Binding="{Binding NumeroTexto}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7C83FF"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Data"  Binding="{Binding DataTexto}"  Width="145">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalTexto}" Width="115">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left" Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#44475A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="finalizado">
                                                        <Setter Property="Background" Value="#00843A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="cancelado">
                                                        <Setter Property="Background" Value="#AA2222"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Pagamento" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3"
                                            HorizontalAlignment="Left" Margin="4,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#44475A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                        <Setter Property="Background" Value="#00843A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                        <Setter Property="Background" Value="#1A5FA8"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                        <Setter Property="Background" Value="#A06010"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormaPagamento}" Value="debito">
                                                        <Setter Property="Background" Value="#4A50C0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding PagamentoTexto}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Operador"  Binding="{Binding Operador}"      Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Separador de itens -->
                <Border Grid.Row="4" Background="#0F0F1A" Padding="0,8"
                        BorderBrush="#2A2A3E" BorderThickness="0,1,0,0" Margin="0,4,0,0">
                    <TextBlock x:Name="histTxtDetalhe"
                               Text="Selecione um pedido para ver os itens"
                               Foreground="#6C6F85" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- DataGrid de itens do pedido selecionado -->
                <DataGrid Grid.Row="5" x:Name="histDgItens"
                          AutoGenerateColumns="False"
                          Background="#13131F" RowBackground="#13131F"
                          AlternatingRowBackground="#1A1A2E"
                          Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A2A3E"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#0F0F1A"/>
                            <Setter Property="Foreground" Value="#6C6F85"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto"      Binding="{Binding NomeProduto}"        Width="*"/>
                        <DataGridTextColumn Header="Qtd"          Binding="{Binding Quantidade}"         Width="55"/>
                        <DataGridTextColumn Header="Preço Unit."  Binding="{Binding PrecoUnitarioTexto}" Width="110"/>
                        <DataGridTextColumn Header="Subtotal"     Binding="{Binding SubtotalTexto}"      Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ PÁGINA: PEDIDOS ══════════════ -->
            <Grid x:Name="pagePedidos" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" MinWidth="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── ESQUERDA: Painel de Pesquisa ── -->
                <Border Grid.Column="0" Background="#13131F"
                        BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Cabeçalho -->
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔎" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PESQUISA DE PEDIDOS"
                                               Foreground="#7C83FF" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Busque por ID ou número sequencial"
                                               Foreground="#44475A" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Botões fixos no rodapé -->
                        <Border DockPanel.Dock="Bottom" Background="#0F0F1A"
                                Padding="12,10" BorderBrush="#2A2A3E" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Limpar / Recentes"
                                        Height="36" FontSize="11" FontWeight="SemiBold"
                                        Foreground="#A0A0C0" Cursor="Hand"
                                        Template="{StaticResource PdvBtnSecundario}"
                                        Click="PedidosBtnLimpar_Click"/>
                                <Button Grid.Column="2" Content="🔍  Buscar"
                                        Height="36" Padding="20,0" FontSize="12" FontWeight="Bold"
                                        Foreground="White" Cursor="Hand"
                                        Template="{StaticResource PdvBtnPrimario}"
                                        Click="PedidosNumpadBuscar_Click"/>
                            </Grid>
                        </Border>

                        <!-- Conteúdo rolável -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,8">

                                <!-- Busca por ID (UUID) -->
                                <TextBlock Text="ID DO PEDIDO (UUID)"
                                           Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="pedidosTxtBuscaId"
                                         Height="40" FontSize="12" Padding="10,0"
                                         Background="#1A1A2E" Foreground="#E0E0E0"
                                         CaretBrush="#7C83FF" BorderBrush="#2A2A3E" BorderThickness="1.5"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         KeyDown="PedidosTxtBuscaId_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Separador OU -->
                                <Grid Margin="0,16,0,16">
                                    <Rectangle Fill="#2A2A3E" Height="1" VerticalAlignment="Center"/>
                                    <Border Background="#13131F" HorizontalAlignment="Center" Padding="10,0">
                                        <TextBlock Text="OU PELO NÚMERO"
                                                   Foreground="#44475A" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- Display numérico -->
                                <Border Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1.5"
                                        CornerRadius="8" Height="58" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock x:Name="pedidosTxtNumero"
                                                   FontSize="30" FontWeight="Bold"
                                                   FontFamily="Consolas"
                                                   Foreground="#7C83FF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <!-- Placeholder quando vazio -->
                                        <TextBlock Text="_ _ _ _"
                                                   FontSize="22" FontWeight="Bold"
                                                   FontFamily="Consolas"
                                                   Foreground="#2A2A3E"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=pedidosTxtNumero}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Teclado numérico -->
                                <UniformGrid Rows="4" Columns="3">
                                    <Button Content="7" Tag="7" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="8" Tag="8" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="9" Tag="9" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="4" Tag="4" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="5" Tag="5" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="6" Tag="6" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="1" Tag="1" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="2" Tag="2" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="3" Tag="3" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>

                                    <Button Content="⌫" Height="52" Margin="3"
                                            FontSize="20" Foreground="#FF6B6B" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpadDel_Click"/>
                                    <Button Content="0" Tag="0" Height="52" Margin="3"
                                            FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpad_Click"/>
                                    <Button Content="↵" Height="52" Margin="3"
                                            FontSize="22" Foreground="#7C83FF" Cursor="Hand"
                                            Template="{StaticResource NumpadBtn}" Click="PedidosNumpadBuscar_Click"/>
                                </UniformGrid>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ── DIREITA: Resultados ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="190" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho + DataGrid de pedidos -->
                    <DockPanel Grid.Row="0">
                        <Border DockPanel.Dock="Top" Background="#0F0F1A" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PEDIDOS" Foreground="#7C83FF"
                                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="pedidosTxtContador"
                                           Foreground="#44475A" FontSize="11"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="dgPedidos"
                                  AutoGenerateColumns="False"
                                  Background="#1E1E2E" RowBackground="#1A1A2E"
                                  AlternatingRowBackground="#181828"
                                  Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" HeadersVisibility="Column"
                                  SelectionChanged="DgPedidos_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#13131F"/>
                                    <Setter Property="Foreground" Value="#7C83FF"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="44"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2A2A5A"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#22223E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"     Binding="{Binding NumeroTexto}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#7C83FF"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Margin" Value="10,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Data"     Binding="{Binding DataTexto}"  Width="135">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Total"    Binding="{Binding TotalTexto}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <!-- Status badge -->
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left" Margin="4,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#44475A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="finalizado">
                                                                <Setter Property="Background" Value="#00843A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="cancelado">
                                                                <Setter Property="Background" Value="#AA2222"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Pagamento badge -->
                                <DataGridTemplateColumn Header="Pagamento" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left" Margin="4,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#44475A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                                <Setter Property="Background" Value="#00843A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                                <Setter Property="Background" Value="#1A5FA8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                                <Setter Property="Background" Value="#A06010"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="debito">
                                                                <Setter Property="Background" Value="#4A50C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PagamentoTexto}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Operador" Binding="{Binding Operador}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- Separador + label de itens -->
                    <Border Grid.Row="1" Background="#0F0F1A" Padding="16,8"
                            BorderBrush="#2A2A3E" BorderThickness="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="pedidosTxtDetalhe"
                                       Text="Selecione um pedido para ver os itens"
                                       Foreground="#6C6F85" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Itens: DataGrid + estado vazio -->
                    <Grid Grid.Row="2">
                        <DataGrid x:Name="dgItensPedido"
                                  AutoGenerateColumns="False"
                                  Background="#13131F" RowBackground="#13131F"
                                  AlternatingRowBackground="#191928"
                                  Foreground="#E0E0E0" BorderBrush="#2A2A3E" BorderThickness="0"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#25253A"
                                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#0F0F1A"/>
                                    <Setter Property="Foreground" Value="#6C6F85"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="10,7"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="38"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto"      Binding="{Binding NomeProduto}"        Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="10,0,0,0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Qtd"          Binding="{Binding Quantidade}"         Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#A0A0C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Preço Unit."  Binding="{Binding PrecoUnitarioTexto}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Subtotal"     Binding="{Binding SubtotalTexto}"      Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Estado vazio -->
                        <StackPanel x:Name="pedidosItensVazio"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="☝" FontSize="36"
                                       HorizontalAlignment="Center" Foreground="#2A2A3E"/>
                            <TextBlock Text="Selecione um pedido acima"
                                       Foreground="#3A3A55" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Página: Usuários -->
            <Grid x:Name="pageUsuarios" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ── -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gerenciar Usuários"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center"/>
                        <Border Background="#2A2A3E" CornerRadius="10" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtUsuarioContador" Text="0 usuários"
                                       FontSize="12" Foreground="#7C83FF" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="+ Novo Usuário"
                            Height="36" Padding="16,0"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#7C83FF" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnNovoUsuario_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Barra de busca ── -->
                <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="#2A2A3E"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="12,0,6,0" Foreground="#6C6F85"/>
                        <TextBox Grid.Column="1" x:Name="txtBuscaUsuario"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#E0E0E0" CaretBrush="#7C83FF"
                                 FontSize="14" Padding="0,10"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtBuscaUsuario_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Buscar por nome..." Foreground="#6C6F85" FontSize="14"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource Hint}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- ── Separador ── -->
                <Border Grid.Row="2" Height="1" Background="#2A2A3E" Margin="0,0,0,0"/>

                <DataGrid Grid.Row="3" x:Name="dgUsuarios"
                          AutoGenerateColumns="False"
                          Background="#13131F"
                          RowBackground="#1A1A2E"
                          AlternatingRowBackground="#1E1E2E"
                          Foreground="#E0E0E0"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#22223A"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223E"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <!-- Avatar -->
                        <DataGridTemplateColumn Header="" Width="58" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" CornerRadius="19"
                                            Margin="6,0" ClipToBounds="True"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <Border Background="#2A2A3E">
                                                <TextBlock Text="{Binding Iniciais}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#7C83FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Nome -->
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#E0E0E0"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Perfil badge -->
                        <DataGridTemplateColumn Header="Perfil" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badgePerfil" CornerRadius="6"
                                            Padding="10,4" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="6,0"
                                            Background="#44475A">
                                        <TextBlock x:Name="txtPerfil" Text="{Binding Perfil}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Perfil}" Value="admin">
                                            <Setter TargetName="badgePerfil" Property="Background" Value="#4A50C0"/>
                                            <Setter TargetName="txtPerfil" Property="Text" Value="Admin"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Perfil}" Value="usuario">
                                            <Setter TargetName="badgePerfil" Property="Background" Value="#2A5A3A"/>
                                            <Setter TargetName="txtPerfil" Property="Text" Value="Usuário"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Ações -->
                        <DataGridTemplateColumn Header="Ações" Width="195" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#3A3A5A" Foreground="#C0C0E0"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Click="BtnEditar_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Editar" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#5A5A8A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Tag="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Background="#5A1A1A" Foreground="#FF9090"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnExcluir_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}" VerticalAlignment="Center">
                                                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Excluir" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#882222"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══════════════ OVERLAY DE CARREGAMENTO ══════════════ -->
            <Grid x:Name="overlayCarregando"
                  Visibility="Collapsed"
                  Panel.ZIndex="999"
                  Background="#CC1E1E2E">
                <Border Background="#252538"
                        BorderBrush="#3A3A55" BorderThickness="1"
                        CornerRadius="14" Padding="48,36"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">

                        <!-- Spinner: borda parcial girando -->
                        <Border x:Name="spinnerBorder"
                                Width="52" Height="52"
                                BorderBrush="#7C83FF"
                                BorderThickness="5,5,0,0"
                                CornerRadius="26"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="spinnerRotate" Angle="0"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard x:Name="spinnerStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="spinnerRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:0.75"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>

                        <TextBlock x:Name="overlayTxtMensagem"
                                   Text="Carregando..."
                                   Foreground="#E0E0E0"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
