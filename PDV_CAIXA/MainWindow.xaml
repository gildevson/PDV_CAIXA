<Window x:Class="PDV_CAIXA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PDV_CAIXA.Converters"
        Title="PDV Caixa"
        Height="580" Width="900"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImage"/>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonActive" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#7C83FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: fixo mas com mínimo -->
            <ColumnDefinition Width="220" MinWidth="200" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ SIDEBAR ══════════════════ -->
        <Border Grid.Column="0" Background="#13131F">
            <DockPanel>

                <!-- Logo topo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Border Background="#7C83FF" CornerRadius="10"
                            Width="40" Height="40" HorizontalAlignment="Center">
                        <TextBlock Text="RME" FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PDV Caixa" FontSize="13" FontWeight="Bold"
                               Foreground="#7C83FF" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,14,16,0"/>

                <!-- Perfil do usuário logado -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,16,0,0">

                    <!-- Avatar circular -->
                    <Grid Width="72" Height="72" HorizontalAlignment="Center">
                        <!-- Fundo -->
                        <Ellipse Fill="#252538"/>

                        <!-- Iniciais (placeholder) -->
                        <TextBlock x:Name="txtIniciais"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#7C83FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Foto real via ImageBrush (garante corte circular perfeito) -->
                        <Ellipse x:Name="ellipseAvatar" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgAvatarBrush"
                                            Stretch="UniformToFill"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Anel roxo por cima -->
                        <Ellipse Stroke="#7C83FF" StrokeThickness="2.5" Fill="Transparent"/>
                    </Grid>

                    <TextBlock x:Name="txtNomeUsuario"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="180"
                               Margin="0,10,0,0"/>

                    <Border Background="#2A2A3E" CornerRadius="10"
                            Padding="10,3" HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                        <TextBlock x:Name="txtPerfilUsuario"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7C83FF"/>
                    </Border>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2A2A3E" Margin="16,16,16,0"/>

                <!-- Botão Sair fixado no rodapé -->
                <Button DockPanel.Dock="Bottom"
                        Content="⬅  Sair"
                        Style="{StaticResource MenuButton}"
                        Margin="0,0,0,16"
                        Click="BtnSair_Click"/>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#2A2A3E" Margin="16,0,16,8"/>

                <!-- Itens de menu -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <TextBlock Text="MENU" FontSize="10"
                               Foreground="#44475A" Margin="24,8,0,6"/>

                    <Button x:Name="btnMenuInicio"
                            Content="🏠  Início"
                            Style="{StaticResource MenuButtonActive}"
                            Click="BtnMenuInicio_Click"/>

                    <Button x:Name="btnMenuUsuarios"
                            Content="👥  Usuários"
                            Style="{StaticResource MenuButton}"
                            Visibility="Collapsed"
                            Click="BtnMenuUsuarios_Click"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════ CONTEÚDO ══════════════════ -->
        <Grid Grid.Column="1">

            <!-- Página: Início -->
            <StackPanel x:Name="pageInicio"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Bem-vindo ao PDV Caixa"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#E0E0E0"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtBemVindo"
                           FontSize="14" Foreground="#6C6F85"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Página: Usuários -->
            <Grid x:Name="pageUsuarios" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Gerenciar Usuários"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#E0E0E0" Margin="0,0,0,16"/>

                <Button Grid.Row="1" Content="+ Novo Usuário"
                        HorizontalAlignment="Left"
                        Height="36" Padding="16,0"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#7C83FF" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,0,0,12"
                        Click="BtnNovoUsuario_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#6970E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <DataGrid Grid.Row="2" x:Name="dgUsuarios"
                          AutoGenerateColumns="False"
                          Background="#13131F"
                          RowBackground="#1A1A2E"
                          AlternatingRowBackground="#1E1E2E"
                          Foreground="#E0E0E0"
                          BorderBrush="#2A2A3E"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2A2A3E"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#13131F"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- Avatar -->
                        <DataGridTemplateColumn Header="" Width="52" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Margin="6,3" ClipToBounds="True"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <!-- Placeholder com iniciais -->
                                            <Border Background="#2A2A3E">
                                                <TextBlock Text="{Binding Iniciais}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="#7C83FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Foto real -->
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Foto, Converter={StaticResource BytesToImage}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Nome"   Binding="{Binding Nome}"   Width="*"/>
                        <DataGridTextColumn Header="Perfil" Binding="{Binding Perfil}" Width="110"/>
                        <DataGridTemplateColumn Header="Ações" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="Editar"
                                                Tag="{Binding}"
                                                Height="26" Padding="10,0" FontSize="11"
                                                Background="#44475A" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,6,0"
                                                Click="BtnEditar_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6C6F85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="Excluir"
                                                Tag="{Binding}"
                                                Height="26" Padding="10,0" FontSize="11"
                                                Background="#FF5555" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnExcluir_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#CC3333"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>
