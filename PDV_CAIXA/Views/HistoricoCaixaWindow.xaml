<Window x:Class="PDV_CAIXA.Views.HistoricoCaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico de Caixa"
        Width="960" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A14">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ PAINEL ESQUERDO — Lista de sessões ══════════════ -->
        <Grid Grid.Column="0" Background="#08080E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#060610" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="HISTÓRICO DE CAIXA"
                               Foreground="#30305A" FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Aberturas e Fechamentos"
                               Foreground="#C0C0E0" FontSize="17" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalSessoes"
                               Foreground="#30305A" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#12122A"/>

            <!-- Filtro rápido -->
            <Border Grid.Row="1" Background="#07070C" Padding="12,10">
                <Grid>
                    <TextBox x:Name="txtFiltro"
                             Height="34" FontSize="12" Padding="32,0,10,0"
                             Background="#0C0C1A" Foreground="#B0B0D0"
                             CaretBrush="#7C83FF" BorderBrush="#1A1A30"
                             BorderThickness="1" VerticalContentAlignment="Center"
                             TextChanged="TxtFiltro_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#3A3A6A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="🔍" FontSize="12" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#2A2A4A"/>
                    <TextBlock Text="Filtrar por data ou operador..."
                               Foreground="#1E1E38" FontSize="11"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="32,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtFiltro}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Bottom" Fill="#10102A"/>

            <!-- Lista de sessões -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="lstSessoes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="card"
                                    Margin="8,4" Padding="14,12" CornerRadius="10"
                                    Cursor="Hand" Background="#0C0C1C"
                                    MouseLeftButtonDown="Card_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Linha 1: Status + Saldo Final -->
                                    <Grid Grid.Row="0">
                                        <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A0A0A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="aberto">
                                                            <Setter Property="Background" Value="#0A1A0E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="⏹ FECHADO"/>
                                                        <Setter Property="Foreground" Value="#553333"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="aberto">
                                                                <Setter Property="Text"       Value="● ABERTO"/>
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="{Binding SaldoFinalTexto}"
                                                   HorizontalAlignment="Right"
                                                   FontSize="14" FontWeight="Bold" Foreground="#C0C0E0"/>
                                    </Grid>

                                    <!-- Linha 2: Abertura -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <TextBlock Text="Abertura: " Foreground="#30305A" FontSize="11"/>
                                        <TextBlock Text="{Binding AberturaTexto}" Foreground="#7070A0" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Linha 3: Fechamento + Operador -->
                                    <Grid Grid.Row="4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fechamento: " Foreground="#22223A" FontSize="10"/>
                                            <TextBlock Text="{Binding FechamentoTexto}" Foreground="#40405A" FontSize="10"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="👤 " FontSize="10" Foreground="#22223A"/>
                                            <TextBlock Text="{Binding NomeOperador}" Foreground="#35355A" FontSize="10"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Separador vertical -->
        <Rectangle Grid.Column="1" Fill="#12122A"/>

        <!-- ══════════════ PAINEL DIREITO — Detalhe da sessão ══════════════ -->
        <Grid Grid.Column="2">

            <!-- Estado: nenhuma sessão selecionada -->
            <StackPanel x:Name="panelVazio"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📋" FontSize="48"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="Selecione uma sessão"
                           Foreground="#20203A" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Clique em uma sessão ao lado para ver os detalhes"
                           Foreground="#14142A" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Estado: sessão selecionada -->
            <Grid x:Name="panelDetalhe" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header da sessão -->
                <Border Grid.Row="0" Background="#0A0A18" Padding="22,16">
                    <Grid>
                        <TextBlock Text="🏦" FontSize="70" Opacity="0.04"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border x:Name="bdStatusDetalhe" CornerRadius="20" Padding="10,3">
                                    <TextBlock x:Name="txtStatusDetalhe"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="txtDetalheAbertura"
                                       Foreground="#E0E0F0" FontSize="18" FontWeight="Bold"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtDetalheOperador"
                                           Foreground="#40405A" FontSize="11"/>
                                <TextBlock Text="  ·  " Foreground="#1E1E30" FontSize="11"/>
                                <TextBlock x:Name="txtDetalheDuracao"
                                           Foreground="#40405A" FontSize="11"/>
                                <TextBlock Text="  ·  " Foreground="#1E1E30" FontSize="11"/>
                                <TextBlock x:Name="txtDetalheFechamento"
                                           Foreground="#40405A" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Rectangle Grid.Row="1" Fill="#10102A"/>

                <!-- Cards de totais -->
                <Border Grid.Row="2" Background="#080812" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0D0D20" CornerRadius="10" Padding="14,11">
                            <StackPanel>
                                <TextBlock Text="SALDO INICIAL" Foreground="#28285A"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtCardSaldoInicial"
                                           Foreground="#5050A0" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#071508" CornerRadius="10" Padding="14,11">
                            <StackPanel>
                                <TextBlock Text="ENTRADAS" Foreground="#1A4020"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtCardEntradas"
                                           Foreground="#50FA7B" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#150808" CornerRadius="10" Padding="14,11">
                            <StackPanel>
                                <TextBlock Text="SAÍDAS" Foreground="#401818"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtCardSaidas"
                                           Foreground="#FF5555" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" CornerRadius="10" Padding="14,11"
                                BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"   Value="#071508"/>
                                    <Setter Property="BorderBrush"  Value="#1A5A22"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="negativo">
                                            <Setter Property="Background"  Value="#150808"/>
                                            <Setter Property="BorderBrush" Value="#5A1A1A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="SALDO FINAL" Foreground="#2A5A30"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtCardSaldoFinal"
                                           Foreground="#50FA7B" FontSize="15" FontWeight="ExtraBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <Rectangle Grid.Row="3" Fill="#10102A"/>

                <!-- Lista de movimentações -->
                <Grid Grid.Row="4" Background="#070710">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#05050C" Padding="20,0">
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="MOVIMENTAÇÕES" Foreground="#1A1A38"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="txtQtdMovs"
                                       HorizontalAlignment="Right"
                                       Foreground="#1A1A38" FontSize="10"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="lstMovs" Margin="0,4,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="12,3" Padding="14,10" CornerRadius="8"
                                            Background="#0C0C1C">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="30" Height="30"
                                                    CornerRadius="15" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#180808"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                                <Setter Property="Background" Value="#071508"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text"       Value="↓"/>
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                                    <Setter Property="Text"       Value="↑"/>
                                                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Descricao}"
                                                           Foreground="#B0B0D0" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding DataTexto}"
                                                               Foreground="#28284A" FontSize="10"/>
                                                    <TextBlock Text=" · " Foreground="#1A1A30" FontSize="10"/>
                                                    <TextBlock Text="{Binding OrigemTexto}"
                                                               Foreground="#20203A" FontSize="10"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding ValorTexto}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <StackPanel VerticalAlignment="Center" Margin="0,24,0,0">
                                                            <TextBlock Text="📭" FontSize="28"
                                                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                            <TextBlock Text="Nenhuma movimentação nesta sessão"
                                                                       Foreground="#14142A" FontSize="12"
                                                                       HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                <Rectangle Grid.Row="5" Fill="#10102A"/>

                <!-- Rodapé -->
                <Border Grid.Row="6" Background="#05050C" Padding="20,12">
                    <Button HorizontalAlignment="Right" Height="38" Padding="22,0"
                            Cursor="Hand" Click="BtnFechar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="9"
                                        BorderBrush="#1C1C38" BorderThickness="1.5"
                                        Background="Transparent">
                                    <TextBlock Text="Fechar" Foreground="#44446A"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#0C0C1A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
