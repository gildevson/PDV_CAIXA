<Window x:Class="PDV_CAIXA.Views.CadastroProdutoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Produto"
        Height="620" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="BorderBrush" Value="#3A3A55"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                    <Setter Property="Background" Value="#2C2C45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Cabeçalho -->
        <Border DockPanel.Dock="Top" Background="#13131F" Padding="24,18">
            <StackPanel Orientation="Horizontal">
                <Border Background="#7C83FF" CornerRadius="10"
                        Width="42" Height="42" Margin="0,0,14,0">
                    <TextBlock Text="📦" FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitulo" Text="Novo Produto"
                               FontSize="16" FontWeight="Bold" Foreground="#E0E0E0"/>
                    <TextBlock x:Name="txtSubtitulo" Text="Preencha os dados do produto"
                               FontSize="11" Foreground="#6C6F85" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Botões rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#13131F" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancelar" Height="40"
                        FontSize="13" Cursor="Hand" Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#2A2A3E"
                                    BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="#A0A0C0"
                                           FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6C6F85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" x:Name="btnSalvar"
                        Content="✔  Salvar Produto" Height="40"
                        FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnSalvar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#7C83FF" CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Formulário -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <!-- Foto do produto -->
                <TextBlock Text="FOTO DO PRODUTO" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="80" Height="80" CornerRadius="10"
                            BorderBrush="#3A3A55" BorderThickness="2"
                            Margin="0,0,16,0" ClipToBounds="True">
                        <Grid>
                            <Border x:Name="fotoPlaceholder" Background="#252538">
                                <TextBlock Text="📦" FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Image x:Name="imgFotoPreview"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <Button Content="📁  Selecionar Foto"
                                Height="34" Padding="14,0" FontSize="12"
                                Cursor="Hand" Click="BtnSelecionarFoto_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="#2A2A3E"
                                            BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="6">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="#A0A0C0" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#7C83FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock x:Name="txtNomeFoto" Text="Nenhuma foto selecionada"
                                   Foreground="#6C6F85" FontSize="10" Margin="0,6,0,0"
                                   TextWrapping="Wrap" MaxWidth="160"/>
                        <Button x:Name="btnRemoverFoto" Content="✕  Remover"
                                Height="26" Padding="10,0" FontSize="11"
                                Cursor="Hand" Margin="0,6,0,0"
                                Visibility="Collapsed"
                                Click="BtnRemoverFoto_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="#FF6B6B" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2A1A1A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Nome -->
                <TextBlock Text="NOME DO PRODUTO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtNome" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtErroNome" Foreground="#FF6B6B" FontSize="11"
                           Margin="0,0,0,12" Visibility="Collapsed"/>

                <!-- Código de barras -->
                <TextBlock Text="CÓDIGO DE BARRAS" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtCodigoBarras" Margin="0,0,0,16"/>

                <!-- Preço e Estoque lado a lado -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PREÇO (R$)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPreco" Text="0,00"/>
                        <TextBlock x:Name="txtErroPreco" Foreground="#FF6B6B" FontSize="11"
                                   Margin="0,2,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ESTOQUE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEstoque" Text="0"/>
                        <TextBlock x:Name="txtErroEstoque" Foreground="#FF6B6B" FontSize="11"
                                   Margin="0,2,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- Descrição -->
                <TextBlock Text="DESCRIÇÃO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtDescricao"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         Padding="12,10"
                         Margin="0,0,0,16"/>

                <!-- Situação -->
                <TextBlock Text="SITUAÇÃO" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="cardAtivo" Grid.Column="0"
                            Background="#252538" BorderBrush="#7C83FF"
                            BorderThickness="1.5" CornerRadius="8"
                            Cursor="Hand" Padding="12,10"
                            MouseLeftButtonDown="CardAtivo_Click">
                        <StackPanel>
                            <TextBlock Text="✔  Ativo" FontSize="13" FontWeight="SemiBold" Foreground="#7C83FF"/>
                            <TextBlock Text="Disponível para venda" FontSize="10" Foreground="#6C6F85" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="cardInativo" Grid.Column="2"
                            Background="#252538" BorderBrush="#3A3A55"
                            BorderThickness="1.5" CornerRadius="8"
                            Cursor="Hand" Padding="12,10"
                            MouseLeftButtonDown="CardInativo_Click">
                        <StackPanel>
                            <TextBlock Text="✘  Inativo" FontSize="13" FontWeight="SemiBold" Foreground="#A0A0C0"/>
                            <TextBlock Text="Fora de venda" FontSize="10" Foreground="#6C6F85" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Erro geral -->
                <TextBlock x:Name="txtErroGeral" Foreground="#FF6B6B" FontSize="12"
                           TextWrapping="Wrap" Margin="0,14,0,0" Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
