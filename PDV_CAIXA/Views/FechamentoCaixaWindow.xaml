<Window x:Class="PDV_CAIXA.Views.FechamentoCaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fechamento de Caixa"
        Width="680" Height="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A16">

    <Grid>
        <!-- Accent bar lateral verde-->
        <Border Width="4" HorizontalAlignment="Left"
                VerticalAlignment="Stretch">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#50FA7B" Offset="0"/>
                    <GradientStop Color="#1A6A30" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>   <!-- drag bar       -->
                <RowDefinition Height="1"/>    <!-- sep            -->
                <RowDefinition Height="Auto"/> <!-- hero/header    -->
                <RowDefinition Height="1"/>    <!-- sep            -->
                <RowDefinition Height="Auto"/> <!-- cards totais   -->
                <RowDefinition Height="1"/>    <!-- sep            -->
                <RowDefinition Height="*"/>    <!-- lista movs     -->
                <RowDefinition Height="1"/>    <!-- sep            -->
                <RowDefinition Height="76"/>   <!-- rodapé botões  -->
            </Grid.RowDefinitions>

            <!-- ══ DRAG BAR ══ -->
            <Border Grid.Row="0" Background="#08081A"
                    MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="11" Height="11" Fill="#FF5F57" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#FEBC2E" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#28C840"/>
                    </StackPanel>
                    <TextBlock Text="RELATÓRIO DE FECHAMENTO"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="10" FontWeight="Bold" Foreground="#2A2A4A"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="30" Height="30" Margin="0,0,4,0"
                            Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                                    <TextBlock Text="✕" Foreground="#44446A" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#2A1010"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            <Rectangle Grid.Row="1" Fill="#12122A"/>

            <!-- ══ HEADER ══ -->
            <Border Grid.Row="2" Background="#0C0C1E" Padding="24,18,24,16">
                <Grid>
                    <!-- Ícone decorativo de fundo -->
                    <TextBlock Text="🏦" FontSize="80" Opacity="0.05"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Margin="0,0,-8,0" IsHitTestVisible="False"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0C2014" BorderBrush="#1A5A22"
                                    BorderThickness="1" CornerRadius="20" Padding="10,3">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="#FF5555"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ENCERRANDO SESSÃO" Foreground="#FF7070"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Text="Fechamento de Caixa"
                                   Foreground="#E8E8F0" FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtOperador"
                                       Foreground="#5A5A7A" FontSize="11"/>
                            <TextBlock Text="  ·  " Foreground="#2A2A3E" FontSize="11"/>
                            <TextBlock x:Name="txtAbertura"
                                       Foreground="#5A5A7A" FontSize="11"/>
                            <TextBlock Text="  ·  " Foreground="#2A2A3E" FontSize="11"/>
                            <TextBlock x:Name="txtDuracao"
                                       Foreground="#5A5A7A" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Rectangle Grid.Row="3" Fill="#12122A"/>

            <!-- ══ CARDS DE TOTAIS ══ -->
            <Border Grid.Row="4" Background="#0A0A18" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Saldo Inicial -->
                    <Border Grid.Column="0" Background="#0E0E20" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="SALDO INICIAL" Foreground="#30305A"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtSaldoInicial"
                                       Foreground="#6060A0" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Entradas -->
                    <Border Grid.Column="2" Background="#081A0E" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="ENTRADAS" Foreground="#1A4A25"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtEntradas"
                                       Foreground="#50FA7B" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Saídas -->
                    <Border Grid.Column="4" Background="#1A0808" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="SAÍDAS" Foreground="#4A1818"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtSaidas"
                                       Foreground="#FF5555" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Saldo Final -->
                    <Border Grid.Column="6" Background="#0C1A0E" CornerRadius="10" Padding="14,12"
                            BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A5A2A" Offset="0"/>
                                <GradientStop Color="#0A2A14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="SALDO FINAL" Foreground="#2A5A35"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtSaldoFinal"
                                       Foreground="#50FA7B" FontSize="16" FontWeight="ExtraBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Rectangle Grid.Row="5" Fill="#12122A"/>

            <!-- ══ LISTA DE MOVIMENTAÇÕES ══ -->
            <Grid Grid.Row="6" Background="#08080E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho da lista -->
                <Border Grid.Row="0" Background="#06060C" Padding="20,0">
                    <Grid VerticalAlignment="Center">
                        <TextBlock Text="MOVIMENTAÇÕES DA SESSÃO"
                                   Foreground="#22224A" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtQtdMovs"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="#22224A" FontSize="10"/>
                    </Grid>
                </Border>

                <!-- Itens -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="lstMovimentacoes" Margin="0,4,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="12,3" Padding="16,10" CornerRadius="8"
                                        Background="#0C0C1A">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Ícone tipo -->
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                CornerRadius="16" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A0808"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                            <Setter Property="Background" Value="#081A0E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="↓"/>
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                                <Setter Property="Text" Value="↑"/>
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Descrição + data -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Descricao}"
                                                       Foreground="#C0C0E0" FontSize="12"
                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DataTexto}"
                                                       Foreground="#30305A" FontSize="10"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Valor -->
                                        <TextBlock Grid.Column="2" Text="{Binding ValorTexto}"
                                                   VerticalAlignment="Center" FontSize="13"
                                                   FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Estado vazio -->
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="0,30,0,0">
                                                        <TextBlock Text="📭" FontSize="32"
                                                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Nenhuma movimentação nesta sessão"
                                                                   Foreground="#1E1E38" FontSize="12"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <Rectangle Grid.Row="7" Fill="#12122A"/>

            <!-- ══ RODAPÉ ══ -->
            <Border Grid.Row="8" Background="#06060E" Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancelar -->
                    <Button Grid.Column="0" Height="46" Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        BorderBrush="#1C1C38" BorderThickness="1.5"
                                        Background="Transparent">
                                    <TextBlock Text="Cancelar" Foreground="#44446A"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#0E0E1E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Confirmar Fechamento -->
                    <Button Grid.Column="2" Height="46" Cursor="Hand" Click="BtnConfirmar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8A1818" Offset="0"/>
                                            <GradientStop Color="#6A1010" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🔒" FontSize="14" Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Confirmar Fechamento" Foreground="White"
                                                   FontSize="14" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
