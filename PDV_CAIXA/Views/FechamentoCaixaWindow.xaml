<Window x:Class="PDV_CAIXA.Views.FechamentoCaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fechamento de Caixa"
        Width="720" Height="680"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A16">

    <Grid>
        <!-- Accent lateral vermelho -->
        <Border Width="4" HorizontalAlignment="Left">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF5555" Offset="0"/>
                    <GradientStop Color="#6A1010" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>    <!-- drag bar        -->
                <RowDefinition Height="1"/>     <!-- sep             -->
                <RowDefinition Height="Auto"/>  <!-- header sessão   -->
                <RowDefinition Height="1"/>     <!-- sep             -->
                <RowDefinition Height="Auto"/>  <!-- cards formas    -->
                <RowDefinition Height="1"/>     <!-- sep             -->
                <RowDefinition Height="Auto"/>  <!-- contagem física -->
                <RowDefinition Height="1"/>     <!-- sep             -->
                <RowDefinition Height="*"/>     <!-- movimentações   -->
                <RowDefinition Height="1"/>     <!-- sep             -->
                <RowDefinition Height="76"/>    <!-- rodapé          -->
            </Grid.RowDefinitions>

            <!-- ══ DRAG BAR ══ -->
            <Border Grid.Row="0" Background="#07071A"
                    MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="11" Height="11" Fill="#FF5F57" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#FEBC2E" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#28C840"/>
                    </StackPanel>
                    <TextBlock Text="FECHAMENTO DE CAIXA"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="10" FontWeight="Bold" Foreground="#25254A"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="30" Height="30" Margin="0,0,4,0"
                            Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                                    <TextBlock Text="✕" Foreground="#44446A" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#2A1010"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            <Rectangle Grid.Row="1" Fill="#12122A"/>

            <!-- ══ HEADER ══ -->
            <Border Grid.Row="2" Background="#0B0B1E" Padding="22,16">
                <Grid>
                    <TextBlock Text="🏦" FontSize="80" Opacity="0.04"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Background="#1A0808" BorderBrush="#4A1818"
                                    BorderThickness="1" CornerRadius="20" Padding="10,3">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="#FF5555"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ENCERRANDO SESSÃO" Foreground="#FF6666"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Fechamento de Caixa"
                                   Foreground="#E8E8F0" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtOperador" Foreground="#44446A" FontSize="11"/>
                            <TextBlock Text="  ·  " Foreground="#22223A" FontSize="11"/>
                            <TextBlock x:Name="txtAbertura" Foreground="#44446A" FontSize="11"/>
                            <TextBlock Text="  ·  " Foreground="#22223A" FontSize="11"/>
                            <TextBlock x:Name="txtDuracao"  Foreground="#44446A" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Rectangle Grid.Row="3" Fill="#12122A"/>

            <!-- ══ CARDS POR FORMA DE PAGAMENTO ══ -->
            <Border Grid.Row="4" Background="#090916" Padding="18,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="TOTAIS POR FORMA DE PAGAMENTO"
                               Foreground="#20204A" FontSize="9" FontWeight="Bold" Margin="2,0,0,0"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dinheiro -->
                        <Border Grid.Column="0" Background="#081508" CornerRadius="10" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="💵 DINHEIRO" Foreground="#1A4020"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFormaDinheiro"
                                           Foreground="#50FA7B" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="caixa físico" Foreground="#0E2A14"
                                           FontSize="9" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Crédito -->
                        <Border Grid.Column="2" Background="#0D0D20" CornerRadius="10" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="💳 CRÉDITO" Foreground="#28285A"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFormaCredito"
                                           Foreground="#7C83FF" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="cartão crédito" Foreground="#16163A"
                                           FontSize="9" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Débito -->
                        <Border Grid.Column="4" Background="#0A0D1A" CornerRadius="10" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="💳 DÉBITO" Foreground="#1E2848"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFormaDebito"
                                           Foreground="#5599FF" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="cartão débito" Foreground="#10162A"
                                           FontSize="9" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- PIX -->
                        <Border Grid.Column="6" Background="#0A180F" CornerRadius="10" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="⚡ PIX" Foreground="#1A4A2A"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFormaPix"
                                           Foreground="#00BDAE" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="transferência" Foreground="#0A2018"
                                           FontSize="9" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Total geral -->
                        <Border Grid.Column="8" CornerRadius="10" Padding="12,10"
                                BorderThickness="1.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0E0E22" Offset="0"/>
                                    <GradientStop Color="#080814" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2A2A5A" Offset="0"/>
                                    <GradientStop Color="#14143A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="TOTAL GERAL" Foreground="#2A2A5A"
                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtTotalGeral"
                                           Foreground="#C0C0F0" FontSize="16" FontWeight="ExtraBold"/>
                                <TextBlock x:Name="txtSaldoInicial"
                                           Foreground="#18183A" FontSize="9" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            <Rectangle Grid.Row="5" Fill="#12122A"/>

            <!-- ══ CONTAGEM FÍSICA (DINHEIRO) ══ -->
            <Border Grid.Row="6" Background="#070710" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Saldo esperado (calculado) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="SALDO ESPERADO" Foreground="#20204A"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtSaldoEsperado"
                                   Foreground="#5050A0" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="calculado pelo sistema" Foreground="#14142A"
                                   FontSize="9" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Campo: valor contado fisicamente -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="VALOR CONTADO (DINHEIRO)" Foreground="#20304A"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Border x:Name="bdContagem" CornerRadius="8" BorderThickness="2"
                                BorderBrush="#1A1A38" Background="#0C0C1E">
                            <Grid Height="46">
                                <TextBlock Text="R$" FontSize="14" FontWeight="Bold"
                                           Foreground="#30305A"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                                <TextBox x:Name="txtContagem"
                                         FontSize="22" FontWeight="Bold"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#C0C0E0" CaretBrush="#7C83FF"
                                         Padding="44,0,10,0" VerticalContentAlignment="Center"
                                         PreviewTextInput="TxtContagem_PreviewTextInput"
                                         TextChanged="TxtContagem_TextChanged"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="informe o valor físico no caixa" Foreground="#14142A"
                                   FontSize="9" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Diferença (sobra / falta) -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <TextBlock Text="DIFERENÇA" Foreground="#20204A"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtDiferenca"
                                   FontSize="18" FontWeight="Bold" Foreground="#44446A"/>
                        <TextBlock x:Name="txtDiferencaLabel"
                                   Foreground="#14142A" FontSize="9" Margin="0,3,0,0"
                                   Text="aguardando contagem..."/>
                    </StackPanel>
                </Grid>
            </Border>
            <Rectangle Grid.Row="7" Fill="#12122A"/>

            <!-- ══ MOVIMENTAÇÕES ══ -->
            <Grid Grid.Row="8" Background="#06060C">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#04040A" Padding="18,0">
                    <Grid VerticalAlignment="Center">
                        <TextBlock Text="MOVIMENTAÇÕES DA SESSÃO"
                                   Foreground="#18183A" FontSize="10" FontWeight="Bold"/>
                        <TextBlock x:Name="txtQtdMovs"
                                   HorizontalAlignment="Right" Foreground="#18183A" FontSize="10"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="lstMovimentacoes" Margin="0,4,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="10,3" Padding="14,9" CornerRadius="8"
                                        Background="#0A0A18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Ícone tipo -->
                                        <Border Grid.Column="0" Width="28" Height="28"
                                                CornerRadius="14" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#160606"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                            <Setter Property="Background" Value="#061606"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="↓"/>
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                                <Setter Property="Text"       Value="↑"/>
                                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Badge forma pagamento -->
                                        <Border Grid.Column="1" CornerRadius="6" Padding="7,3"
                                                Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0E0E20"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                            <Setter Property="Background" Value="#061408"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                            <Setter Property="Background" Value="#0C0C24"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                            <Setter Property="Background" Value="#061410"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FormaTexto}"
                                                       FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2A2A48"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="dinheiro">
                                                                <Setter Property="Foreground" Value="#30A050"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="credito">
                                                                <Setter Property="Foreground" Value="#5560CC"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="debito">
                                                                <Setter Property="Foreground" Value="#3366CC"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormaPagamento}" Value="pix">
                                                                <Setter Property="Foreground" Value="#00998A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Descrição + data -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Descricao}"
                                                       Foreground="#A0A0C0" FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DataTexto}"
                                                       Foreground="#1E1E38" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Valor -->
                                        <TextBlock Grid.Column="3" Text="{Binding ValorTexto}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo}" Value="entrada">
                                                            <Setter Property="Foreground" Value="#50FA7B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <Rectangle Grid.Row="9" Fill="#12122A"/>

            <!-- ══ RODAPÉ ══ -->
            <Border Grid.Row="10" Background="#050510" Padding="22,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2.2*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Height="46" Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        BorderBrush="#1C1C38" BorderThickness="1.5"
                                        Background="Transparent">
                                    <TextBlock Text="Cancelar" Foreground="#44446A"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#0C0C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnConfirmar" Grid.Column="2" Height="46"
                            Cursor="Hand" Click="BtnConfirmar_Click" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10" Opacity="{TemplateBinding Opacity}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8A1818" Offset="0"/>
                                            <GradientStop Color="#6A1010" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🔒" FontSize="14" Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Confirmar Fechamento" Foreground="White"
                                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
