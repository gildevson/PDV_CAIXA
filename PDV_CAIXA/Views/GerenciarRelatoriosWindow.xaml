<Window x:Class="PDV_CAIXA.Views.GerenciarRelatoriosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração de Relatórios"
        Height="500" Width="700"
        MinHeight="400" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <DockPanel>

        <!-- Cabeçalho -->
        <Border DockPanel.Dock="Top" Background="#13131F" Padding="24,18">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#7C83FF" CornerRadius="10"
                            Width="42" Height="42" Margin="0,0,14,0">
                        <TextBlock Text="⚙" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Configuração de Relatórios"
                                   FontSize="16" FontWeight="Bold" Foreground="#E0E0E0"/>
                        <TextBlock Text="Gerencie os relatórios disponíveis para impressão"
                                   FontSize="11" Foreground="#6C6F85" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Height="34" Padding="16,0"
                        FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnNovo_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#7C83FF" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="14" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Novo Relatório" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#13131F" Padding="24,12">
            <Button Content="Fechar" HorizontalAlignment="Right"
                    Height="36" Padding="24,0" FontSize="13" Cursor="Hand"
                    Click="BtnFechar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A3E"
                                BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="8">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="#A0A0C0"
                                       FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

        <!-- Lista -->
        <DataGrid x:Name="dgConfigs"
                  AutoGenerateColumns="False"
                  Background="#1A1A2E" RowBackground="#1E1E30"
                  AlternatingRowBackground="#1A1A2E"
                  Foreground="#C0C0D8" BorderThickness="0"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A2A40"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  Margin="0,1,0,0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"       Value="#13131F"/>
                    <Setter Property="Foreground"       Value="#40406A"/>
                    <Setter Property="FontWeight"       Value="Bold"/>
                    <Setter Property="FontSize"         Value="10"/>
                    <Setter Property="Padding"          Value="14,10"/>
                    <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                    <Setter Property="BorderBrush"      Value="#2A2A40"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="42"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0D2A3A"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#22223A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#00BCD4"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="14,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Arquivo .rdlc" Binding="{Binding NomeArquivo}" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="4,0"/>
                            <Setter Property="Foreground" Value="#7C83FF"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ativo" Binding="{Binding AtivoTexto}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="4,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="4,0"/>
                            <Setter Property="Foreground" Value="#6C6F85"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Ações" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <Button Content="✏ Editar" Height="26" Padding="10,0"
                                        FontSize="10" FontWeight="SemiBold"
                                        Background="#0C1428" Foreground="#7C83FF"
                                        BorderThickness="1" BorderBrush="#1A2A4A"
                                        Cursor="Hand" Margin="0,0,6,0"
                                        Tag="{Binding}" Click="BtnEditar_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#141C38"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="🗑" Height="26" Width="30" FontSize="12"
                                        Background="#1A0808" Foreground="#FF6B6B"
                                        BorderThickness="1" BorderBrush="#2A1010"
                                        Cursor="Hand" Tag="{Binding}" Click="BtnExcluir_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#2A0C0C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
