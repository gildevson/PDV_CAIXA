<Window x:Class="PDV_CAIXA.Views.MovimentacaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="580"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <!-- Layout em StackPanel: cresce para baixo automaticamente,
         nunca corta conteúdo. Barra lateral usa um Grid externo. -->
    <Grid>
        <!-- Accent bar lateral — Background definido no code-behind -->
        <Border x:Name="bdAccent" Width="4" HorizontalAlignment="Left"/>

        <Grid Margin="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <!-- drag bar  -->
                <RowDefinition Height="Auto"/>
                <!-- separador -->
                <RowDefinition Height="Auto"/>
                <!-- hero      -->
                <RowDefinition Height="Auto"/>
                <!-- separador -->
                <RowDefinition Height="Auto"/>
                <!-- form      -->
                <RowDefinition Height="Auto"/>
                <!-- separador -->
                <RowDefinition Height="84"/>
                <!-- rodapé    -->
            </Grid.RowDefinitions>

            <!-- ══ DRAG BAR ══ -->
            <Border Grid.Row="0" Background="#14142A"
                    MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="11" Height="11" Fill="#FF5F57" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#FEBC2E" Margin="0,0,7,0"/>
                        <Ellipse Width="11" Height="11" Fill="#28C840"/>
                    </StackPanel>
                    <TextBlock x:Name="txtBarraTipo"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="10" FontWeight="SemiBold" Foreground="#35355A"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="30" Height="30" Margin="0,0,4,0"
                            Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                                    <TextBlock Text="✕" Foreground="#44446A" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A1520"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            <Rectangle Grid.Row="1" Height="1" Fill="#1E1E38"/>

            <!-- ══ HERO ══ -->
            <Border Grid.Row="2" Padding="0,22,0,20" Background="#16162C">
                <StackPanel HorizontalAlignment="Center">
                    <Border x:Name="bdIconCircle" Width="88" Height="88"
                            CornerRadius="44" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Grid>
                            <TextBlock x:Name="txtIcone" FontSize="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtIconeDecor" FontSize="18"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,4,4"/>
                        </Grid>
                    </Border>
                    <Border x:Name="bdPill" HorizontalAlignment="Center"
                            CornerRadius="20" Padding="18,6" Margin="0,0,0,10">
                        <TextBlock x:Name="txtSubtitulo" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock x:Name="txtTitulo" FontSize="24" FontWeight="Bold"
                               Foreground="#E8E8F0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Rectangle Grid.Row="3" Height="1" Fill="#1E1E38"/>

            <!-- ══ FORMULÁRIO ══ -->
            <StackPanel Grid.Row="4" Margin="30,22,30,22">

                <TextBlock Text="DESCRIÇÃO" Foreground="#44446A"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,7"/>
                <Border CornerRadius="10" BorderThickness="1.5" BorderBrush="#1E1E3C"
                        Background="#0E0E1E" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="Ex: Compra de insumos, pagamento de fornecedor..."
                                   Foreground="#26264A" FontSize="12"
                                   Margin="13,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtDescricao}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="txtDescricao" FontSize="15"
                                 Background="Transparent" Foreground="#D0D0E8"
                                 CaretBrush="#7C83FF" BorderThickness="0"
                                 Padding="13,12" VerticalContentAlignment="Center"
                                 KeyDown="TxtDescricao_KeyDown"/>
                    </Grid>
                </Border>

                <TextBlock Text="VALOR (R$)" Foreground="#44446A"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,7"/>
                <Border x:Name="bdValor" CornerRadius="10" BorderThickness="2">
                    <Grid Height="70">
                        <TextBlock x:Name="txtRS" Text="R$" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="18,0,0,0"/>
                        <TextBox x:Name="txtValor" FontSize="34" FontWeight="Bold"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="50,0,14,0" VerticalContentAlignment="Center"
                                 PreviewTextInput="TxtValor_PreviewTextInput"
                                 KeyDown="TxtValor_KeyDown"/>
                    </Grid>
                </Border>

                <TextBlock Foreground="#24244A" FontSize="11" Margin="2,8,0,0"
                           Text="↵  Enter confirma  ·  Tab navega entre campos"/>
            </StackPanel>

            <Rectangle Grid.Row="5" Height="1" Fill="#1E1E38"/>

            <!-- ══ RODAPÉ ══ -->
            <Border Grid.Row="6" Background="#0E0E1C" Padding="30,0,30,0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-0.362"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1.8*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Height="50" Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        BorderBrush="#1C1C38" BorderThickness="1.5"
                                        Background="Transparent">
                                    <TextBlock Text="Cancelar" Foreground="#44446A"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#14142A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnConfirmar" Grid.Column="2" Height="50"
                            FontSize="15" FontWeight="Bold" Cursor="Hand"
                            Click="BtnConfirmar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10" Background="#1A7035">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#22904A"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="saida">
                                        <Setter TargetName="bd" Property="Background" Value="#7A1818"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
