<Window x:Class="PDV_CAIXA.Views.CadastroRelatorioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Relatório"
        Height="480" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="BorderBrush" Value="#3A3A55"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                    <Setter Property="Background" Value="#2C2C45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Cabeçalho -->
        <Border DockPanel.Dock="Top" Background="#13131F" Padding="24,18">
            <StackPanel Orientation="Horizontal">
                <Border Background="#7C83FF" CornerRadius="10"
                        Width="42" Height="42" Margin="0,0,14,0">
                    <TextBlock Text="📊" FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitulo" Text="Novo Relatório"
                               FontSize="16" FontWeight="Bold" Foreground="#E0E0E0"/>
                    <TextBlock x:Name="txtSubtitulo" Text="Preencha os dados do relatório"
                               FontSize="11" Foreground="#6C6F85" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Botões rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#13131F" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancelar" Height="40"
                        FontSize="13" Cursor="Hand" Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#2A2A3E"
                                    BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="#A0A0C0"
                                           FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#33334A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6C6F85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" x:Name="btnSalvar"
                        Content="✔  Salvar Relatório" Height="40"
                        FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnSalvar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#7C83FF" CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3A55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Formulário -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <!-- Nome -->
                <TextBlock Text="NOME DO RELATÓRIO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtNome" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtErroNome" Foreground="#FF6B6B" FontSize="11"
                           Margin="0,0,0,12" Visibility="Collapsed"/>

                <!-- Tipo -->
                <TextBlock Text="TIPO" Style="{StaticResource FieldLabel}"/>
                <Border Background="#252538" BorderBrush="#3A3A55" BorderThickness="1.5"
                        CornerRadius="4" Height="40" Margin="0,0,0,4">
                    <ComboBox x:Name="cmbTipo"
                              Background="Transparent" BorderThickness="0"
                              FontSize="13" Foreground="#E0E0E0"
                              VerticalContentAlignment="Center"
                              Padding="10,0"
                              SelectionChanged="CmbTipo_SelectionChanged">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton Background="Transparent" BorderThickness="0"
                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Focusable="False" ClickMode="Press">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#44446A"
                                                                               FontSize="11" VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                  IsHitTestVisible="False"
                                                                  VerticalAlignment="Center"
                                                                  Margin="12,0,28,0"/>
                                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       Placement="Bottom" AllowsTransparency="True"
                                                       Focusable="False" PopupAnimation="Slide">
                                                    <Border Background="#0C0C1A" BorderBrush="#2A2A4A"
                                                            BorderThickness="1"
                                                            MinWidth="{TemplateBinding ActualWidth}">
                                                        <ScrollViewer>
                                                            <StackPanel IsItemsHost="True"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#0C0C1A"/>
                                <Setter Property="Foreground" Value="#D0D0E0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="12,9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#1A1A3A"/>
                                        <Setter Property="Foreground" Value="#7C83FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#14142E"/>
                                        <Setter Property="Foreground" Value="#A0A4FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Produtos Cadastrados" Tag="Produtos"/>
                        <ComboBoxItem Content="Usuários Cadastrados"  Tag="Usuarios"/>
                    </ComboBox>
                </Border>
                <TextBlock x:Name="txtErroTipo" Foreground="#FF6B6B" FontSize="11"
                           Margin="0,0,0,12" Visibility="Collapsed"/>

                <!-- Nome do Arquivo -->
                <TextBlock Text="NOME DO ARQUIVO (sem extensão)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtNomeArquivo" Margin="0,0,0,4"
                         ToolTip="Ex: RelatorioProdutos.rdlc"/>
                <TextBlock Foreground="#44446A" FontSize="10" Margin="0,0,0,4"
                           Text="Informe o arquivo .rdlc. Ex: RelatorioProdutos.rdlc"/>
                <TextBlock x:Name="txtErroNomeArquivo" Foreground="#FF6B6B" FontSize="11"
                           Margin="0,0,0,12" Visibility="Collapsed"/>

                <!-- Descrição -->
                <TextBlock Text="DESCRIÇÃO (opcional)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtDescricao"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         Padding="12,10"
                         Margin="0,0,0,16"/>

                <!-- Ordem -->
                <TextBlock Text="ORDEM DE EXIBIÇÃO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtOrdem" Text="0" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtErroOrdem" Foreground="#FF6B6B" FontSize="11"
                           Margin="0,0,0,12" Visibility="Collapsed"/>

                <!-- Situação -->
                <TextBlock Text="SITUAÇÃO" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="cardAtivo" Grid.Column="0"
                            Background="#252538" BorderBrush="#7C83FF"
                            BorderThickness="1.5" CornerRadius="8"
                            Cursor="Hand" Padding="12,10"
                            MouseLeftButtonDown="CardAtivo_Click">
                        <StackPanel>
                            <TextBlock Text="✔  Ativo" FontSize="13" FontWeight="SemiBold" Foreground="#7C83FF"/>
                            <TextBlock Text="Aparece na lista" FontSize="10" Foreground="#6C6F85" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="cardInativo" Grid.Column="2"
                            Background="#252538" BorderBrush="#3A3A55"
                            BorderThickness="1.5" CornerRadius="8"
                            Cursor="Hand" Padding="12,10"
                            MouseLeftButtonDown="CardInativo_Click">
                        <StackPanel>
                            <TextBlock Text="✘  Inativo" FontSize="13" FontWeight="SemiBold" Foreground="#A0A0C0"/>
                            <TextBlock Text="Oculto na lista" FontSize="10" Foreground="#6C6F85" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Erro geral -->
                <TextBlock x:Name="txtErroGeral" Foreground="#FF6B6B" FontSize="12"
                           TextWrapping="Wrap" Margin="0,14,0,0" Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
