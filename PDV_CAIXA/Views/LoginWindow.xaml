<Window x:Class="PDV_CAIXA.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV Caixa — Login"
        MinHeight="380" MinWidth="320"
        Height="480" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#44475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#44475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7C83FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#7C83FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6970E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#555BC4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#44475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Grid principal: divide a tela em painel lateral + formulário -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*" MinWidth="0"/>
            <ColumnDefinition Width="0.6*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel lateral esquerdo -->
        <Border Grid.Column="0" Background="#13131F">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                <!-- Logo RME -->
                <Border Background="#7C83FF"
                        CornerRadius="16"
                        Width="72" Height="72"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="RME"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               />
                </Border>
                <TextBlock Text="PDV"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#7C83FF"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="CAIXA"
                           FontSize="18" FontWeight="Light"
                           Foreground="#A0A0C0"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
                <Rectangle Height="1" Fill="#2A2A3E" Margin="0,0,0,24"/>
                <TextBlock Text="Sistema de Ponto de Venda"
                           FontSize="11"
                           Foreground="#6C6F85"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Formulário direito -->
        <Border Grid.Column="1" Background="#1E1E2E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1"
                            Margin="32,0"
                            VerticalAlignment="Center">

                    <TextBlock Text="Bem-vindo"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#E0E0E0"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Faça login para acessar o sistema"
                               FontSize="12"
                               Foreground="#6C6F85"
                               Margin="0,0,0,28"/>

                    <TextBlock Text="Usuário"
                               Foreground="#A0A0B0"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsuario"/>

                    <TextBlock Text="Senha"
                               Foreground="#A0A0B0"
                               FontSize="12"
                               Margin="0,16,0,6"/>
                    <PasswordBox x:Name="pwdSenha"/>

                    <TextBlock x:Name="txtStatus"
                               Foreground="#FF5555"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>

                    <Button x:Name="btnLogin"
                            Content="Entrar"
                            Margin="0,20,0,0"
                            Click="BtnLogin_Click"/>
                </StackPanel>

                <!-- Rodapé -->
                <TextBlock Grid.Row="2"
                           Text="PDV Caixa v1.0"
                           Foreground="#44475A"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
