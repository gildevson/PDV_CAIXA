<Window x:Class="PDV_CAIXA.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV Caixa — Login"
        Height="580" Width="720"
        MinHeight="460" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E2E">

    <Window.Resources>

        <!-- Input com ícone: TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bdr" Background="#1E1E32"
                                BorderBrush="#3A3A5A" BorderThickness="1.5"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="icon" Grid.Column="0"
                                           Text="👤" FontSize="16"
                                           Foreground="#6C6F85"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#7C83FF"/>
                                <Setter TargetName="bdr" Property="Background" Value="#22224A"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#7C83FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input com ícone: PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bdr" Background="#1E1E32"
                                BorderBrush="#3A3A5A" BorderThickness="1.5"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="icon" Grid.Column="0"
                                           Text="🔒" FontSize="16"
                                           Foreground="#6C6F85"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#7C83FF"/>
                                <Setter TargetName="bdr" Property="Background" Value="#22224A"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#7C83FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.42*"/>
            <ColumnDefinition Width="0.58*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ PAINEL ESQUERDO ══════════ -->
        <Border Grid.Column="0" Background="#0D0D1A" ClipToBounds="True">
            <Grid>
                <!-- Camada 1: círculos decorativos (preenche tudo) -->
                <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Ellipse Canvas.Left="-60" Canvas.Top="-60"
                             Width="260" Height="260"
                             Fill="#7C83FF" Opacity="0.06"/>
                    <Ellipse Canvas.Left="80" Canvas.Top="360"
                             Width="200" Height="200"
                             Fill="#7C83FF" Opacity="0.08"/>
                    <Ellipse Canvas.Left="-10" Canvas.Top="200"
                             Width="90" Height="90"
                             Fill="#50FA7B" Opacity="0.04"/>
                </Canvas>

                <!-- Camada 2: conteúdo centralizado (escala com a janela) -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="24">

                    <!-- Anel externo -->
                    <Border Width="92" Height="92" CornerRadius="23"
                            BorderBrush="#7C83FF" BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,0" Opacity="0.35"/>

                    <!-- Logo (sobreposto ao anel) -->
                    <Border Width="78" Height="78" CornerRadius="19"
                            Background="#7C83FF"
                            HorizontalAlignment="Center"
                            Margin="0,-88,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#7C83FF" BlurRadius="28"
                                              ShadowDepth="0" Opacity="0.65"/>
                        </Border.Effect>
                        <TextBlock Text="RME"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="PDV"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#7C83FF"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#7C83FF" BlurRadius="14"
                                              ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="C A I X A"
                               FontSize="13" FontWeight="Light"
                               Foreground="#8080A0"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,30"/>

                    <Rectangle Height="1" Fill="#2A2A3E"
                               HorizontalAlignment="Stretch" Margin="20,0,20,18"/>

                    <TextBlock Text="Sistema de Ponto de Venda"
                               FontSize="11" Foreground="#4A4A6A"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════ PAINEL DIREITO ══════════ -->
        <Border Grid.Column="1" Background="#1A1A2E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="48,0">

                    <!-- Título -->
                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="Bem-vindo 👋"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#E0E0E0" Margin="0,0,0,6"/>
                        <TextBlock Text="Faça login para acessar o sistema"
                                   FontSize="12" Foreground="#5A5A7A"/>
                    </StackPanel>

                    <!-- Label Usuário -->
                    <TextBlock Text="USUÁRIO" Foreground="#5A5A7A"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="2,0,0,6"/>
                    <TextBox x:Name="txtUsuario"/>

                    <!-- Label Senha -->
                    <TextBlock Text="SENHA" Foreground="#5A5A7A"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="2,18,0,6"/>
                    <PasswordBox x:Name="pwdSenha"
                                 KeyDown="PwdSenha_KeyDown">
                        <PasswordBox.RenderTransform>
                            <TranslateTransform/>
                        </PasswordBox.RenderTransform>
                    </PasswordBox>

                    <!-- Mensagem de erro -->
                    <Border x:Name="borderErro" CornerRadius="8" Padding="12,10"
                            Background="#3A1010" BorderBrush="#882222" BorderThickness="1"
                            Margin="0,14,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="txtErroIcone"
                                       Text="🔐" FontSize="18"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="txtStatus"
                                           Foreground="#FF7070" FontSize="13" FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="txtTentativas"
                                           Foreground="#884444" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Botão Entrar -->
                    <Button x:Name="btnLogin" Margin="0,20,0,0"
                            Height="46" Cursor="Hand"
                            Click="BtnLogin_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        Background="#7C83FF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#7C83FF" BlurRadius="16"
                                                          ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Entrar" FontSize="15" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text=" →" FontSize="15" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#555BC4"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Background" Value="#2A2A3E"/>
                                        <Setter TargetName="bd" Property="Effect" Value="{x:Null}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <!-- Rodapé -->
                <TextBlock Grid.Row="2"
                           Text="PDV Caixa v1.0"
                           Foreground="#2E2E4E" FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,14"/>
            </Grid>
        </Border>
    </Grid>
</Window>
