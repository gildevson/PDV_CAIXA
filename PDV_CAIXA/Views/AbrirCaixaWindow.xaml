<Window x:Class="PDV_CAIXA.Views.AbrirCaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abrir Caixa"
        Height="391" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🏦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Abrir Caixa" FontSize="18" FontWeight="Bold"
                       Foreground="#E0E0E0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Label -->
        <TextBlock Grid.Row="1" Text="SALDO INICIAL (dinheiro em caixa)"
                   Foreground="#6C6F85" FontSize="10" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Input saldo -->
        <Border Grid.Row="2" Background="#1A1A2E" BorderBrush="#448AFF"
                BorderThickness="2" CornerRadius="8">
            <Grid>
                <TextBlock Text="R$" Foreground="#6C6F85" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <TextBox x:Name="txtSaldo"
                         FontSize="22" FontWeight="Bold"
                         Background="Transparent" Foreground="#448AFF"
                         CaretBrush="#448AFF" BorderThickness="0"
                         Padding="38,10,14,10" Text="0,00"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="TxtSaldo_PreviewTextInput"
                         KeyDown="TxtSaldo_KeyDown" TextChanged="txtSaldo_TextChanged"/>
            </Grid>
        </Border>

        <!-- Informação -->
        <TextBlock Grid.Row="3" Text="Digite 0,00 se não houver dinheiro em caixa."
                   Foreground="#44475A" FontSize="11"
                   Margin="0,8,0,0" VerticalAlignment="Top"/>

        <!-- Botões -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancelar" Height="100"
                    FontSize="13" Foreground="#6C6F85" Cursor="Hand"
                    Click="BtnCancelar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" BorderBrush="#2A2A3E"
                                BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Content="✓  Abrir Caixa" Height="42"
                    FontSize="13" FontWeight="Bold" Foreground="White" Cursor="Hand"
                    Click="BtnConfirmar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#1A6A30" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#228840"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
