<Window x:Class="PDV_CAIXA.Views.PesarProdutoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pesar Produto"
        Height="430" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <DockPanel>

        <!-- Cabeçalho -->
        <Border DockPanel.Dock="Top" Background="#13131F" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Border Background="#2A2A42" CornerRadius="12"
                        Width="48" Height="48" Margin="0,0,14,0">
                    <TextBlock Text="⚖️" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtNomeProduto" Text="Produto"
                               FontSize="17" FontWeight="Bold" Foreground="#E0E0F0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="Preço: " FontSize="12" Foreground="#6C6F85"/>
                        <TextBlock x:Name="txtPrecoPorKg" FontSize="12"
                                   Foreground="#7C83FF" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Botões rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#13131F" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancelar" Height="42"
                        FontSize="13" Cursor="Hand" Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#252538"
                                    BorderBrush="#3A3A55" BorderThickness="1.5" CornerRadius="10">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="#A0A0C0"
                                           FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2E2E48"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#5A5A75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" x:Name="btnConfirmar"
                        Content="✔  Confirmar" Height="42"
                        FontSize="13" FontWeight="Bold"
                        IsEnabled="False" Cursor="Hand" Click="BtnConfirmar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#7C83FF" CornerRadius="10">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#6970E0"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="#2A2A42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Conteúdo -->
        <StackPanel Margin="20,20,20,0" VerticalAlignment="Center">

            <!-- Campos kg e gramas -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Campo KG -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="QUILOGRAMAS" Foreground="#6C6F85" FontSize="10"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border x:Name="borderKg" Background="#252538" BorderBrush="#3A3A55"
                            BorderThickness="1.5" CornerRadius="12" Height="70">
                        <StackPanel VerticalAlignment="Center">
                            <TextBox x:Name="txtKg" Text="0"
                                     FontSize="28" FontWeight="Bold"
                                     Foreground="#E0E0F0" Background="Transparent"
                                     BorderThickness="0" TextAlignment="Center"
                                     CaretBrush="#7C83FF"
                                     VerticalContentAlignment="Center"
                                     TextChanged="Peso_TextChanged"
                                     KeyDown="Peso_KeyDown"
                                     GotFocus="Peso_GotFocus"/>
                            <TextBlock Text="kg" Foreground="#5A5A75" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,-2,0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Separador + -->
                <TextBlock Grid.Column="1" Text="+"
                           FontSize="24" FontWeight="Light" Foreground="#3A3A55"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,22"/>

                <!-- Campo Gramas -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="GRAMAS" Foreground="#6C6F85" FontSize="10"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border x:Name="borderGramas" Background="#252538" BorderBrush="#3A3A55"
                            BorderThickness="1.5" CornerRadius="12" Height="70">
                        <StackPanel VerticalAlignment="Center">
                            <TextBox x:Name="txtGramas" Text="0"
                                     FontSize="28" FontWeight="Bold"
                                     Foreground="#E0E0F0" Background="Transparent"
                                     BorderThickness="0" TextAlignment="Center"
                                     CaretBrush="#7C83FF"
                                     VerticalContentAlignment="Center"
                                     TextChanged="Peso_TextChanged"
                                     KeyDown="Peso_KeyDown"
                                     GotFocus="Peso_GotFocus"/>
                            <TextBlock Text="g" Foreground="#5A5A75" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,-2,0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Erro -->
            <TextBlock x:Name="txtErroPeso" Foreground="#FF6B6B" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       Visibility="Collapsed"/>

            <!-- Preview do total -->
            <Border x:Name="borderTotal" CornerRadius="12" Margin="0,16,0,0"
                    Padding="0,16" Visibility="Collapsed">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2E1A" Offset="0"/>
                        <GradientStop Color="#162616" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2A5A2A" Offset="0"/>
                        <GradientStop Color="#1E4A1E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel>
                    <TextBlock x:Name="txtResumo" Foreground="#5A8A5A" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock x:Name="txtTotal" Foreground="#50FA7B"
                               FontSize="30" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </DockPanel>
</Window>
