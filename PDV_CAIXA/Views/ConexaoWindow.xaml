<Window x:Class="PDV_CAIXA.Views.ConexaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV Caixa — Configuração de Conexão"
        Height="540" Width="480"
        MinHeight="480" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="Campo" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="Background" Value="#1E1E32"/>
            <Setter Property="BorderBrush" Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bdr"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#7C83FF"/>
                                <Setter TargetName="bdr" Property="Background" Value="#22224A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CampoSenha" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#7C83FF"/>
            <Setter Property="Background" Value="#1E1E32"/>
            <Setter Property="BorderBrush" Value="#3A3A5A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bdr"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#7C83FF"/>
                                <Setter TargetName="bdr" Property="Background" Value="#22224A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6C6F85"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>

        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#7C83FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6670EE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A5A"/>
                                <Setter Property="Foreground" Value="#6C6F85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#35354E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="36,30,36,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🔌" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Configuração de Conexão" FontSize="18" FontWeight="Bold"
                       Foreground="#E0E0E0" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtSubtitulo"
                       Text="Configure os dados de acesso ao banco de dados PostgreSQL."
                       FontSize="12" Foreground="#6C6F85" HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Formulário -->
        <StackPanel Grid.Row="1">

            <!-- Servidor + Porta (lado a lado) -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SERVIDOR (HOST)" Style="{StaticResource Label}"/>
                    <TextBox x:Name="txtHost" Style="{StaticResource Campo}" Text="localhost"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="PORTA" Style="{StaticResource Label}"/>
                    <TextBox x:Name="txtPorta" Style="{StaticResource Campo}" Text="5432"/>
                </StackPanel>
            </Grid>

            <!-- Banco de Dados -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="BANCO DE DADOS" Style="{StaticResource Label}"/>
                <TextBox x:Name="txtBanco" Style="{StaticResource Campo}"/>
            </StackPanel>

            <!-- Usuário -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="USUÁRIO" Style="{StaticResource Label}"/>
                <TextBox x:Name="txtUsuario" Style="{StaticResource Campo}" Text="postgres"/>
            </StackPanel>

            <!-- Senha -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="SENHA" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="txtSenha" Style="{StaticResource CampoSenha}"/>
            </StackPanel>

            <!-- Status do teste -->
            <Border x:Name="borderStatus" Visibility="Collapsed"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtStatusIcone" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtStatusMsg" FontSize="12" Foreground="#E0E0E0"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Botões -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="btnTestar" Content="🔍  Testar Conexão"
                    Style="{StaticResource BtnPrimario}"
                    Click="BtnTestar_Click"/>
            <Button Grid.Column="2" x:Name="btnCancelar" Content="Cancelar"
                    Style="{StaticResource BtnSecundario}"
                    Click="BtnCancelar_Click"/>
        </Grid>
    </Grid>
</Window>
