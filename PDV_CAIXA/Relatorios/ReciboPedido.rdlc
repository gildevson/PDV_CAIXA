<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>b1c2d3e4-0000-0000-0000-000000000010</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSetItens">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="TipoLinha">
          <DataField>TipoLinha</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Esquerda">
          <DataField>Esquerda</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Direita">
          <DataField>Direita</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>

          <!-- ── Nome da Empresa ── -->
          <Textbox Name="txtEmpresa">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!NomeEmpresa.Value</Value>
                    <Style><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a1a2e</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.3cm</Top><Left>0cm</Left><Height>0.9cm</Height><Width>17cm</Width>
            <ZIndex>1</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Telefone ── -->
          <Textbox Name="txtTelefone">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!Telefone.Value</Value>
                    <Style><FontSize>9pt</FontSize><Color>#44446a</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>1.3cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>17cm</Width>
            <ZIndex>2</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Endereço ── -->
          <Textbox Name="txtEndereco">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!EnderecoEmpresa.Value</Value>
                    <Style><FontSize>9pt</FontSize><Color>#44446a</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>1.85cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>17cm</Width>
            <ZIndex>3</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Cidade/UF ── -->
          <Textbox Name="txtCidade">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!CidadeEmpresa.Value</Value>
                    <Style><FontSize>9pt</FontSize><Color>#44446a</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>2.4cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>17cm</Width>
            <ZIndex>4</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Barra escura ── -->
          <Textbox Name="sep1">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style/></TextRun></TextRuns><Style/></Paragraph></Paragraphs>
            <Top>3.0cm</Top><Left>0cm</Left><Height>0.08cm</Height><Width>17cm</Width>
            <ZIndex>5</ZIndex>
            <Style><Border><Style>None</Style></Border><BackgroundColor>#1a1a2e</BackgroundColor></Style>
          </Textbox>

          <!-- ── Título RECIBO DE VENDA ── -->
          <Textbox Name="txtTitulo">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>RECIBO DE VENDA</Value>
                    <Style><FontSize>15pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a1a2e</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>3.18cm</Top><Left>0cm</Left><Height>0.9cm</Height><Width>17cm</Width>
            <ZIndex>6</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Barra clara ── -->
          <Textbox Name="sep2">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style/></TextRun></TextRuns><Style/></Paragraph></Paragraphs>
            <Top>4.18cm</Top><Left>0cm</Left><Height>0.08cm</Height><Width>17cm</Width>
            <ZIndex>7</ZIndex>
            <Style><Border><Style>None</Style></Border><BackgroundColor>#ccccdd</BackgroundColor></Style>
          </Textbox>

          <!-- ── Número do Pedido ── -->
          <Textbox Name="txtNumero">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Nº " &amp; Parameters!NumeroPedido.Value</Value>
                    <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>#1a1a2e</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Left</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>4.38cm</Top><Left>0cm</Left><Height>0.5cm</Height><Width>8.5cm</Width>
            <ZIndex>8</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Data do Pedido ── -->
          <Textbox Name="txtData">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!DataPedido.Value</Value>
                    <Style><FontSize>10pt</FontSize><Color>#44446a</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Right</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>4.38cm</Top><Left>8.5cm</Left><Height>0.5cm</Height><Width>8.5cm</Width>
            <ZIndex>9</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Operador ── -->
          <Textbox Name="txtOperador">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Operador: " &amp; Parameters!Operador.Value</Value>
                    <Style><FontSize>9pt</FontSize><Color>#44446a</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Left</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>4.98cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>17cm</Width>
            <ZIndex>10</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>

          <!-- ── Barra clara antes da tabela ── -->
          <Textbox Name="sep3">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style/></TextRun></TextRuns><Style/></Paragraph></Paragraphs>
            <Top>5.53cm</Top><Left>0cm</Left><Height>0.08cm</Height><Width>17cm</Width>
            <ZIndex>11</ZIndex>
            <Style><Border><Style>None</Style></Border><BackgroundColor>#ccccdd</BackgroundColor></Style>
          </Textbox>

          <!-- ══════════════════════════════════════════
               TABLIX — 2 colunas, sem ColSpan
               Coluna 1: 12cm (produto / labels)
               Coluna 2:  5cm (valor, right-align)
               Linhas: 1 header + 1 detail (item + footer via DataTable)
               ══════════════════════════════════════════ -->
          <Tablix Name="TblRecibo">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>12cm</Width></TablixColumn>
                <TablixColumn><Width>5cm</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>

                <!-- ─── Header ─── -->
                <TablixRow>
                  <Height>0.7cm</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="hProduto">
                          <Paragraphs><Paragraph>
                            <TextRuns><TextRun>
                              <Value>PRODUTO</Value>
                              <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                            </TextRun></TextRuns>
                            <Style><TextAlign>Left</TextAlign></Style>
                          </Paragraph></Paragraphs>
                          <Style>
                            <Border><Color>#0a0a18</Color><Style>Solid</Style></Border>
                            <BackgroundColor>#1a1a2e</BackgroundColor>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>6pt</PaddingLeft>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="hValor">
                          <Paragraphs><Paragraph>
                            <TextRuns><TextRun>
                              <Value>TOTAL</Value>
                              <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                            </TextRun></TextRuns>
                            <Style><TextAlign>Right</TextAlign></Style>
                          </Paragraph></Paragraphs>
                          <Style>
                            <Border><Color>#0a0a18</Color><Style>Solid</Style></Border>
                            <BackgroundColor>#1a1a2e</BackgroundColor>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingRight>4pt</PaddingRight>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── Detail (item + footer via DataTable) ─── -->
                <TablixRow>
                  <Height>0.55cm</Height>
                  <TablixCells>

                    <!-- Coluna esquerda -->
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="dEsquerda">
                          <CanGrow>true</CanGrow>
                          <Paragraphs><Paragraph>
                            <TextRuns><TextRun>
                              <Value>=Fields!Esquerda.Value</Value>
                              <Style>
                                <FontSize>=IIF(Fields!TipoLinha.Value = "total", "11pt", "9pt")</FontSize>
                                <FontWeight>=IIF(Fields!TipoLinha.Value = "total" Or Fields!TipoLinha.Value = "pagto_h", "Bold", "Normal")</FontWeight>
                                <Color>=Switch(Fields!TipoLinha.Value = "sep_dark", "#1a1a2e", Fields!TipoLinha.Value = "pagto_h", "#44446a", Fields!TipoLinha.Value = "obrigado", "#44446a", True, "#333333")</Color>
                                <FontStyle>=IIF(Fields!TipoLinha.Value = "obrigado", "Italic", "Normal")</FontStyle>
                              </Style>
                            </TextRun></TextRuns>
                            <Style><TextAlign>=Switch(Fields!TipoLinha.Value = "obrigado", "Center", Fields!TipoLinha.Value = "total", "Right", True, "Left")</TextAlign></Style>
                          </Paragraph></Paragraphs>
                          <Style>
                            <Border>
                              <Style>=IIF(Fields!TipoLinha.Value = "item", "Solid", "None")</Style>
                              <Color>#ccccdd</Color>
                              <Width>0.5pt</Width>
                            </Border>
                            <BackgroundColor>=Switch(Fields!TipoLinha.Value = "sep_dark", "#1a1a2e", Fields!TipoLinha.Value = "sep_light", "#d4d4e8", Fields!TipoLinha.Value = "total", "#eeeef8", True, "Transparent")</BackgroundColor>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>=IIF(Fields!TipoLinha.Value = "item", "6pt", "4pt")</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>

                    <!-- Coluna direita -->
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="dDireita">
                          <Paragraphs><Paragraph>
                            <TextRuns><TextRun>
                              <Value>=Fields!Direita.Value</Value>
                              <Style>
                                <FontSize>=IIF(Fields!TipoLinha.Value = "total", "11pt", "9pt")</FontSize>
                                <FontWeight>=IIF(Fields!TipoLinha.Value = "total", "Bold", "Normal")</FontWeight>
                                <Color>=IIF(Fields!TipoLinha.Value = "sep_dark", "#1a1a2e", "#333333")</Color>
                              </Style>
                            </TextRun></TextRuns>
                            <Style><TextAlign>Right</TextAlign></Style>
                          </Paragraph></Paragraphs>
                          <Style>
                            <Border>
                              <Style>=IIF(Fields!TipoLinha.Value = "item", "Solid", "None")</Style>
                              <Color>#ccccdd</Color>
                              <Width>0.5pt</Width>
                            </Border>
                            <BackgroundColor>=Switch(Fields!TipoLinha.Value = "sep_dark", "#1a1a2e", Fields!TipoLinha.Value = "sep_light", "#d4d4e8", Fields!TipoLinha.Value = "total", "#eeeef8", True, "Transparent")</BackgroundColor>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingRight>4pt</PaddingRight>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>

                  </TablixCells>
                </TablixRow>

              </TablixRows>
            </TablixBody>

            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember/>
                <TablixMember/>
              </TablixMembers>
            </TablixColumnHierarchy>

            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember>
                  <KeepWithGroup>After</KeepWithGroup>
                  <RepeatOnNewPage>true</RepeatOnNewPage>
                  <KeepTogether>true</KeepTogether>
                </TablixMember>
                <TablixMember>
                  <Group Name="GrupoLinhas"/>
                </TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>

            <DataSetName>DataSetItens</DataSetName>
            <Top>5.71cm</Top>
            <Left>0cm</Left>
            <Height>1.25cm</Height>
            <Width>17cm</Width>
            <ZIndex>12</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Tablix>

        </ReportItems>
        <Height>4cm</Height>
        <Style/>
      </Body>
      <Width>17cm</Width>
      <Page>
        <PageHeight>29.7cm</PageHeight>
        <PageWidth>21cm</PageWidth>
        <LeftMargin>2cm</LeftMargin>
        <RightMargin>2cm</RightMargin>
        <TopMargin>1.5cm</TopMargin>
        <BottomMargin>1.5cm</BottomMargin>
        <Style/>
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="NomeEmpresa">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Nome da Empresa</Prompt>
    </ReportParameter>
    <ReportParameter Name="Telefone">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Telefone</Prompt>
    </ReportParameter>
    <ReportParameter Name="EnderecoEmpresa">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Endereço</Prompt>
    </ReportParameter>
    <ReportParameter Name="CidadeEmpresa">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Cidade/UF</Prompt>
    </ReportParameter>
    <ReportParameter Name="NumeroPedido">
      <DataType>String</DataType>
      <DefaultValue><Values><Value>00000</Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Número do Pedido</Prompt>
    </ReportParameter>
    <ReportParameter Name="DataPedido">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Data do Pedido</Prompt>
    </ReportParameter>
    <ReportParameter Name="Operador">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <AllowBlank>true</AllowBlank>
      <Prompt>Operador</Prompt>
    </ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Cm</rd:ReportUnitType>
  <rd:ReportID>c3d4e5f6-2222-3333-4444-000000000005</rd:ReportID>
</Report>
