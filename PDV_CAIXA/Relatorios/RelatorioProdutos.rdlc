<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">

  <!-- ── DataSource ───────────────────────────────────────────── -->
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>a1b2c3d4-0000-0000-0000-000000000001</rd:DataSourceID>
    </DataSource>
  </DataSources>

  <!-- ── DataSet ──────────────────────────────────────────────── -->
  <DataSets>
    <DataSet Name="DataSetProdutos">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="Nome"><DataField>Nome</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CodigoBarras"><DataField>CodigoBarras</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Preco"><DataField>Preco</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Desconto"><DataField>Desconto</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Estoque"><DataField>Estoque</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Ativo"><DataField>Ativo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>

  <!-- ── Parâmetros ───────────────────────────────────────────── -->
  <ReportParameters>
    <ReportParameter Name="DataGeracao">
      <DataType>String</DataType>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <Prompt>Data de Geração</Prompt>
    </ReportParameter>
    <ReportParameter Name="TotalProdutos">
      <DataType>String</DataType>
      <DefaultValue><Values><Value>0</Value></Values></DefaultValue>
      <Prompt>Total de Produtos</Prompt>
    </ReportParameter>
  </ReportParameters>

  <!-- ── Corpo ────────────────────────────────────────────────── -->
  <Body>
    <ReportItems>

      <!-- Título -->
      <Textbox Name="txtTitulo">
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>RELATÓRIO DE PRODUTOS CADASTRADOS</Value>
                <Style>
                  <FontFamily>Arial</FontFamily>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                  <Color>#1A1A2E</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Center</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>0.5cm</Top>
        <Left>0cm</Left>
        <Width>17cm</Width>
        <Height>1cm</Height>
        <Style><Border><Style>None</Style></Border></Style>
      </Textbox>

      <!-- Subtítulo / data geração -->
      <Textbox Name="txtSubtitulo">
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=Parameters!DataGeracao.Value &amp; "   •   Total: " &amp; Parameters!TotalProdutos.Value &amp; " produto(s)"</Value>
                <Style>
                  <FontFamily>Arial</FontFamily>
                  <FontSize>9pt</FontSize>
                  <Color>#44446A</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Center</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>1.7cm</Top>
        <Left>0cm</Left>
        <Width>17cm</Width>
        <Height>0.6cm</Height>
        <Style><Border><Style>None</Style></Border></Style>
      </Textbox>

      <!-- Tabela de produtos -->
      <Tablix Name="tblProdutos">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>5.5cm</Width></TablixColumn>
            <TablixColumn><Width>3.0cm</Width></TablixColumn>
            <TablixColumn><Width>2.5cm</Width></TablixColumn>
            <TablixColumn><Width>2.5cm</Width></TablixColumn>
            <TablixColumn><Width>2.0cm</Width></TablixColumn>
            <TablixColumn><Width>1.5cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>

            <!-- Cabeçalho -->
            <TablixRow>
              <Height>0.7cm</Height>
              <TablixCells>

                <TablixCell><CellContents>
                  <Textbox Name="hNome">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>NOME</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Left</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingLeft>4pt</PaddingLeft>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="hCodigo">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>CÓD. BARRAS</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Left</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingLeft>4pt</PaddingLeft>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="hPreco">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>PREÇO</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="hDesconto">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>DESCONTO</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="hEstoque">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>ESTOQUE</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="hAtivo">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>ATIVO</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Center</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <BackgroundColor>#1A1A2E</BackgroundColor>
                      <VerticalAlign>Middle</VerticalAlign>
                      <BorderColor><Default>#0A0A18</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>1pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

              </TablixCells>
            </TablixRow>

            <!-- Linha de dados -->
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>

                <TablixCell><CellContents>
                  <Textbox Name="dNome">
                    <CanGrow>true</CanGrow>
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!Nome.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Left</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingLeft>4pt</PaddingLeft>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="dCodigo">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!CodigoBarras.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Left</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingLeft>4pt</PaddingLeft>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="dPreco">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!Preco.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="dDesconto">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!Desconto.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="dEstoque">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!Estoque.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Right</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <PaddingRight>4pt</PaddingRight>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

                <TablixCell><CellContents>
                  <Textbox Name="dAtivo">
                    <Paragraphs><Paragraph>
                      <TextRuns><TextRun>
                        <Value>=Fields!Ativo.Value</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns>
                      <Style><TextAlign>Center</TextAlign></Style>
                    </Paragraph></Paragraphs>
                    <Style>
                      <VerticalAlign>Middle</VerticalAlign>
                      <BorderColor><Default>#CCCCDD</Default></BorderColor>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderWidth><Default>0.5pt</Default></BorderWidth>
                    </Style>
                  </Textbox>
                </CellContents></TablixCell>

              </TablixCells>
            </TablixRow>

          </TablixRows>
        </TablixBody>

        <TablixColumnHierarchy>
          <TablixMembers>
            <TablixMember/>
            <TablixMember/>
            <TablixMember/>
            <TablixMember/>
            <TablixMember/>
            <TablixMember/>
          </TablixMembers>
        </TablixColumnHierarchy>

        <TablixRowHierarchy>
          <TablixMembers>
            <TablixMember>
              <KeepWithGroup>After</KeepWithGroup>
              <RepeatOnNewPage>true</RepeatOnNewPage>
              <KeepTogether>true</KeepTogether>
            </TablixMember>
            <TablixMember>
              <Group Name="GrupoProdutos"/>
            </TablixMember>
          </TablixMembers>
        </TablixRowHierarchy>

        <DataSetName>DataSetProdutos</DataSetName>
        <Top>2.6cm</Top>
        <Left>0cm</Left>
        <Width>17cm</Width>
        <Style><Border><Style>None</Style></Border></Style>
      </Tablix>

    </ReportItems>
    <Height>29cm</Height>
    <Style/>
  </Body>

  <!-- ── Cabeçalho de página ──────────────────────────────────── -->
  <PageHeader>
    <Height>0.4cm</Height>
    <PrintOnFirstPage>false</PrintOnFirstPage>
    <PrintOnLastPage>true</PrintOnLastPage>
    <ReportItems>
      <Textbox Name="pgHeader">
        <Paragraphs><Paragraph>
          <TextRuns><TextRun>
            <Value>RELATÓRIO DE PRODUTOS — continuação</Value>
            <Style><FontFamily>Arial</FontFamily><FontSize>7pt</FontSize><Color>#44446A</Color></Style>
          </TextRun></TextRuns>
          <Style><TextAlign>Center</TextAlign></Style>
        </Paragraph></Paragraphs>
        <Top>0cm</Top><Left>0cm</Left><Width>17cm</Width><Height>0.4cm</Height>
        <Style><Border><Style>None</Style></Border></Style>
      </Textbox>
    </ReportItems>
  </PageHeader>

  <!-- ── Rodapé de página ─────────────────────────────────────── -->
  <PageFooter>
    <Height>0.6cm</Height>
    <PrintOnFirstPage>true</PrintOnFirstPage>
    <PrintOnLastPage>true</PrintOnLastPage>
    <ReportItems>
      <Textbox Name="pgFooterLeft">
        <Paragraphs><Paragraph>
          <TextRuns><TextRun>
            <Value>PDV Caixa — Relatório de Produtos</Value>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#44446A</Color></Style>
          </TextRun></TextRuns>
          <Style><TextAlign>Left</TextAlign></Style>
        </Paragraph></Paragraphs>
        <Top>0.1cm</Top><Left>0cm</Left><Width>8.5cm</Width><Height>0.4cm</Height>
        <Style><Border><Style>None</Style></Border></Style>
      </Textbox>
      <Textbox Name="pgFooterRight">
        <Paragraphs><Paragraph>
          <TextRuns><TextRun>
            <Value>=Parameters!DataGeracao.Value &amp; "   Pág. " &amp; Globals!PageNumber &amp; " / " &amp; Globals!TotalPages</Value>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#44446A</Color></Style>
          </TextRun></TextRuns>
          <Style><TextAlign>Right</TextAlign></Style>
        </Paragraph></Paragraphs>
        <Top>0.1cm</Top><Left>8.5cm</Left><Width>8.5cm</Width><Height>0.4cm</Height>
        <Style><Border><Style>None</Style></Border></Style>
      </Textbox>
    </ReportItems>
  </PageFooter>

  <!-- ── Página A4 ─────────────────────────────────────────────── -->
  <Width>17cm</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>1.5cm</TopMargin>
    <BottomMargin>1.5cm</BottomMargin>
    <Style/>
  </Page>
  <rd:ReportUnitType>Cm</rd:ReportUnitType>
</Report>
